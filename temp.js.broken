// Inventory is server-backed only — never seed demo rows; empty API / invalid JSON must stay [].

let inventory = [];
let locations = [];
let loans = [];
let huntItems = [];
let currentLoanId = null, currentDetailId = null, currentLocationId = 'storage';
let inventoryLocationFilter = 'all';
let huntCategoryFilter = 'all';

console.log('Inventory data on load:', items?.length || 'no items loaded');

