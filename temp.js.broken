}

// ── Inventory Summary ────────────────────────────────────────
let inventorySummaryPeriod = 'ytd'; // Default to "Year to Date"
let inventorySummaryLocationFilter = 'all'; // Default to "All Locations"

function populateInventorySummaryLocationFilter() {
  const select = document.getElementById('inventory-summary-location-filter');
  if (!select) return;

  // Clear existing options except "All Locations"
  select.innerHTML = '<option value="all">All Locations</option>';

  // Add active (non-archived) locations
  const activeLocations = locations.filter(loc => loc.active && !loc.archived);
  activeLocations.forEach(loc => {
    const option = document.createElement('option');
    option.value = loc.id;
    option.textContent = loc.name;
    select.appendChild(option);
  });

  // Set current selection
  select.value = inventorySummaryLocationFilter;
}

function setInventorySummaryLocationFilter() {
  const select = document.getElementById('inventory-summary-location-filter');
  inventorySummaryLocationFilter = select.value;
  renderInventorySummary();
}

function setInventorySummaryPeriod(period) {
  inventorySummaryPeriod = period;

  // Update button states
  document.querySelectorAll('[id^="inventory-summary-period-"]').forEach(btn => {
    btn.classList.remove('active');
  });
  document.getElementById(`inventory-summary-period-${period}`).classList.add('active');

  renderInventorySummary();
}

function renderInventorySummary() {
  const bounds = getInventorySummaryBounds();

  // Calculate inventory metrics based on location and period filters
  let totalItems = 0;
  let totalUnits = 0;
  let totalCost = 0;
  let totalRetail = 0;
  let totalSoldUnits = 0;
  let totalSoldRevenue = 0;

  inventory.forEach(item => {
    // Filter by location if not 'all'
    let itemQty = 0;
    let itemCost = Number(item.cost) + Number(item.labor);
    let itemRetail = Number(item.suggestedPrice ?? item.salePrice ?? 0);

    if (inventorySummaryLocationFilter === 'all') {
      // Sum across all locations
      itemQty = item.totalQty || 0;
    } else {
      // Use only the selected location's quantity
      itemQty = Number(item.inventory?.[inventorySummaryLocationFilter]?.qty || 0);
    }

    // Count items with stock
    if (itemQty > 0) {
      totalItems++;
      totalUnits += itemQty;
      totalCost += itemCost * itemQty;
      totalRetail += itemRetail * itemQty;
    }

    // Calculate sales within the period
    const periodSales = (item.sales || []).filter(sale => {
      if (!sale.date) return false;
      const saleDate = new Date(sale.date);
      return saleDate >= bounds.start && saleDate <= bounds.end;
    }).filter(sale => {
      // Filter by location if not 'all'
      return inventorySummaryLocationFilter === 'all' || sale.location === inventorySummaryLocationFilter;
    });

    totalSoldUnits += periodSales.reduce((sum, sale) => sum + Number(sale.qty), 0);
    totalSoldRevenue += periodSales.reduce((sum, sale) => sum + Number(sale.revenue), 0);
  });

  // Update the display elements
  document.getElementById('inventory-summary-items').textContent = totalItems;
  document.getElementById('inventory-summary-units').textContent = totalUnits;
  document.getElementById('inventory-summary-cost').textContent = fmtK(totalCost);
  document.getElementById('inventory-summary-retail').textContent = fmtK(totalRetail);

  // Show/hide sold summary strip
  const soldStrip = document.getElementById('inventory-summary-sold-strip');
  if (totalSoldUnits > 0) {
    soldStrip.style.display = 'grid';
    document.getElementById('inventory-summary-sold-units').textContent = totalSoldUnits;
    document.getElementById('inventory-summary-sold-revenue').textContent = fmtK(totalSoldRevenue);
  } else {
    soldStrip.style.display = 'none';
  }

  // Update last updated timestamp
  const lastUpdatedEl = document.getElementById('pnl-last-updated');
  if (lastUpdatedEl) {
    lastUpdatedEl.textContent = new Date().toLocaleString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
      hour: 'numeric', minute: '2-digit', hour12: true
    });
  }
}

function getInventorySummaryBounds() {
  const now = new Date(), y = now.getFullYear(), m = now.getMonth();
  if (inventorySummaryPeriod === 'ytd') {
    return { start: new Date(y, 0, 1), end: now, label: `Jan 1 – Today ${y}` };
  }
  if (inventorySummaryPeriod === 'month') {
    const label = now.toLocaleDateString('en-US', { month:'long', year:'numeric' });
    return { start: new Date(y, m, 1), end: new Date(y, m+1, 0, 23, 59, 59), label };
  }
  // last month
  const lm = m === 0 ? 11 : m-1, ly = m === 0 ? y-1 : y;
  const label = new Date(ly, lm, 1).toLocaleDateString('en-US', { month:'long', year:'numeric' });
  return { start: new Date(ly, lm, 1), end: new Date(ly, lm+1, 0, 23, 59, 59), label };
}

function renderIndividualSales() {
  const bounds = getIndividualSalesBounds();
  const sales = getIndividualSalesData(bounds);

  const container = document.getElementById('individual-sales-list');
  if (!container) return;

  if (!sales.length) {
    container.innerHTML = `
      <div style="text-align:center;padding:40px;color:var(--text3);">
        <div style="font-size:48px;margin-bottom:16px;">📊</div>
        <div style="font-size:16px;font-weight:700;margin-bottom:8px;">No Sales Found</div>
        <div style="font-size:14px;">No individual sales recorded for the selected period and location.</div>
      </div>
    `;
    return;
  }

  // Sort sales by date (newest first)
  sales.sort((a, b) => new Date(b.date) - new Date(a.date));

  // Add category breakdown
  const categorySection = renderIndividualSalesCategories(sales);

  container.innerHTML = sales.map(sale => {
    const locationName = locations.find(l => l.id === sale.location)?.name || 'Unknown Location';
    const profitColor = sale.profit >= 0 ? 'var(--accent2)' : 'var(--danger)';
    const profitSign = sale.profit >= 0 ? '+' : '';

    // Calculate metrics for this sale
    const item = sale.item;
    const suggested = Number(item.suggestedPrice ?? item.salePrice ?? 0);
    const location = locations.find(l => l.id === sale.location);
    const transactionFeePercent = location?.transactionFeePercent || 0;
    const effectiveRevenue = suggested * (1 - transactionFeePercent / 100);
    const cost = Number(item.cost) + Number(item.labor);
    const adjustedProfit = effectiveRevenue - cost;
    const adjustedMargin = suggested > 0 ? Math.round((adjustedProfit / suggested) * 100) : 0;

    return `
      <div class="inv-card" style="margin-bottom:12px;">
        <div class="inv-card-header">
          <div style="flex:1;padding-right:10px;">
            <div class="inv-name">${esc(sale.item.name)}</div>
            <span class="category-chip">${esc(sale.item.category)}</span>
            <div style="font-size:11px;color:var(--accent);font-weight:600;margin-top:4px;">📍 ${esc(locationName)}</div>
          </div>
          <div style="text-align:right;">
            <div style="font-size:12px;font-weight:700;font-family:var(--font-mono);margin-bottom:4px;color:${profitColor};">
              ${profitSign}${fmt(sale.profit)}
            </div>
            <div style="font-size:10px;color:var(--text3);font-family:var(--font-mono);">
              ${new Date(sale.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
            </div>
          </div>
        </div>
      <div class="inv-metrics">
        <div class="inv-metric"><div class="inv-metric-label">Cost</div><div class="inv-metric-value cost">${fmt(item.cost)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Labor</div><div class="inv-metric-value cost">${fmt(item.labor)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Fee</div><div class="inv-metric-value">${transactionFeePercent}%</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Revenue</div><div class="inv-metric-value highlight">${fmt(sale.revenue)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Margin</div><div class="inv-metric-value price">${adjustedMargin}%</div></div>
      </div>
    `;
  }).join('') + categorySection;

  // Update last updated timestamp
  const lastUpdatedEl = document.getElementById('pnl-last-updated');
  if (lastUpdatedEl) {
    lastUpdatedEl.textContent = new Date().toLocaleString('en-US', {
      month: 'short', day: 'numeric', year: 'numeric',
      hour: 'numeric', minute: '2-digit', hour12: true
    });
  }
}

function getIndividualSalesBounds() {
  const now = new Date(), y = now.getFullYear(), m = now.getMonth();
  if (individualSalesPeriod === 'ytd') {
    return { start: new Date(y, 0, 1), end: now, label: `Jan 1 – Today ${y}` };
  }
  if (individualSalesPeriod === 'month') {
    const label = now.toLocaleDateString('en-US', { month:'long', year:'numeric' });
    return { start: new Date(y, m, 1), end: new Date(y, m+1, 0, 23, 59, 59), label };
  }
  // last month
  const lm = m === 0 ? 11 : m-1, ly = m === 0 ? y-1 : y;
  const label = new Date(ly, lm, 1).toLocaleDateString('en-US', { month:'long', year:'numeric' });
  return { start: new Date(ly, lm, 1), end: new Date(ly, lm+1, 0, 23, 59, 59), label };
}

function getIndividualSalesData(bounds) {
  // Get all sales within the date range
  const sales = inventory.flatMap(item =>
    (item.sales || [])
      .filter(sale => {
        if (!sale.date) return false;
        const saleDate = new Date(sale.date);
        return saleDate >= bounds.start && saleDate <= bounds.end;
      })
      .map(sale => ({ ...sale, item }))
  );

  // Filter by location if not 'all'
  if (individualSalesLocationFilter !== 'all') {
    return sales.filter(sale => sale.location === individualSalesLocationFilter);
  }

  return sales;
}

function renderIndividualSalesCategories(sales) {
  // Group sales by category
  const byCategory = {};
  sales.forEach(sale => {
    const cat = sale.item.category || 'Other';
    if (!byCategory[cat]) byCategory[cat] = { revenue: 0, profit: 0, units: 0 };
    byCategory[cat].revenue += Number(sale.revenue);
    byCategory[cat].profit += Number(sale.profit);
    byCategory[cat].units += Number(sale.qty);
  });

  if (Object.keys(byCategory).length === 0) {
    return '';
  }

  const catRows = Object.entries(byCategory)
    .sort((a, b) => b[1].revenue - a[1].revenue)
    .map(([cat, d]) => {
      const margin = d.revenue > 0 ? Math.round((d.profit / d.revenue) * 100) : 0;
      return `<div class="pnl-row">
        <div>
          <div class="pnl-row-label">${esc(cat)}</div>
          <div style="font-size:11px;color:var(--text3);font-family:var(--font-mono);margin-top:2px;">
            ${d.units} unit${d.units !== 1 ? 's' : ''} sold
          </div>
        </div>
        <div style="text-align:right;">
          <div style="font-family:var(--font-mono);font-size:15px;font-weight:600;color:${d.profit >= 0 ? 'var(--accent2)' : 'var(--danger)'}">${fmt(d.revenue)}</div>
          <div style="font-size:10px;color:${d.profit >= 0 ? 'var(--accent2)' : 'var(--danger)'}font-family:var(--font-mono);">${fmt(d.profit)} profit (${margin}% margin)</div>
        </div>
      </div>`;
    }).join('');

  return `
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:10px;padding:0 16px;">
      <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);">By Category</div>
      <div style="font-size:10px;color:var(--text3);font-family:var(--font-mono);">${sales.length} sale${sales.length !== 1 ? 's' : ''}</div>
    </div>
    <div class="pnl-card" style="margin-bottom:20px;">${catRows}</div>
  `;
}

// ── Test Location Filtering ──────────────────────────────────
function testLocationFiltering() {
  console.log('Testing location filtering...');

  // Test 1: Check if location setup validation works
  const activeLocations = locations.filter(loc => loc.active);
  console.log(`Active locations: ${activeLocations.length}`);

  // Test 2: Check if location filter dropdown is populated
  populatePnLLocationFilter();
  const select = document.getElementById('pnl-location-filter');
  console.log(`Location filter options: ${select ? select.options.length : 0}`);

  // Test 3: Test filtering logic
  const testItems = [
    { id: '1', name: 'Test Item 1', qty: 5, inventory: { 'loc1': { qty: 3 }, 'loc2': { qty: 2 } } },
    { id: '2', name: 'Test Item 2', qty: 0, inventory: {} }
  ];

  const filterItemsByLocation = (items) => {
    if (pnlLocationFilter === 'all') return items;
    return items.filter(item => {
      if (!item.inventory) return false;
      return item.inventory[pnlLocationFilter] && Number(item.inventory[pnlLocationFilter].qty) > 0;
    });
  };

  const filtered = filterItemsByLocation(testItems);
  console.log(`Filtered items (${pnlLocationFilter}): ${filtered.length}`);

  // Test 4: Test sales filtering by location
  const testSales = [
    { item: { id: '1' }, date: '2024-01-01', qty: 1, revenue: 100, profit: 50 },
    { item: { id: '2' }, date: '2024-01-02', qty: 2, revenue: 200, profit: 100 }
  ];

  const filterSalesByLocation = (sales) => {
    if (pnlLocationFilter === 'all') return sales;
    return sales.filter(sale => {
      // Find the item and check if it has inventory at the selected location
      const item = inventory.find(i => i.id === sale.item.id);
      if (!item || !item.inventory) return false;
      return item.inventory[pnlLocationFilter] && Number(item.inventory[pnlLocationFilter].qty) >= 0;
    });
  };

  const filteredSales = filterSalesByLocation(testSales);
  console.log(`Filtered sales (${pnlLocationFilter}): ${filteredSales.length}`);

  console.log('Location filtering test complete');
}

function getPeriodBounds() {
  const now   = new Date();
  const y     = now.getFullYear();
  const m     = now.getMonth();        // 0-based
  if (pnlPeriod === 'ytd') {
    // end = today, not Dec 31 — so we only count expenses that have actually occurred
    return { start: new Date(y, 0, 1), end: now, label: `Jan 1 – Today ${y}` };
  }
  if (pnlPeriod === 'month') {
    const label = now.toLocaleDateString('en-US', { month:'long', year:'numeric' });
    return { start: new Date(y, m, 1), end: new Date(y, m+1, 0, 23, 59, 59), label };
  }
  // last month
  const lm    = m === 0 ? 11 : m-1;
  const ly    = m === 0 ? y-1 : y;
  const label = new Date(ly, lm, 1).toLocaleDateString('en-US', { month:'long', year:'numeric' });
  return { start: new Date(ly, lm, 1), end: new Date(ly, lm+1, 0, 23, 59, 59), label };
}

function getIncomeStatementBounds() {
  const now   = new Date();
  const y     = now.getFullYear();
  const m     = now.getMonth();        // 0-based
  if (incomeStatementPeriod === 'ytd') {
    // end = today, not Dec 31 — so we only count expenses that have actually occurred
    return { start: new Date(y, 0, 1), end: now, label: `Jan 1 – Today ${y}` };
  }
  if (incomeStatementPeriod === 'month') {
    const label = now.toLocaleDateString('en-US', { month:'long', year:'numeric' });
    return { start: new Date(y, m, 1), end: new Date(y, m+1, 0, 23, 59, 59), label };
  }
  // last month
  const lm    = m === 0 ? 11 : m-1;
  const ly    = m === 0 ? y-1 : y;
  const label = new Date(ly, lm, 1).toLocaleDateString('en-US', { month:'long', year:'numeric' });
  return { start: new Date(ly, lm, 1), end: new Date(ly, lm+1, 0, 23, 59, 59), label };
}

// ── Income Statement Calculations ───────────────────────────────────
function calculateIncomeStatement(bounds) {
  // Revenue: All sales in the period (gross revenue before transaction fees)
  const periodSales = inventory.flatMap(i => salesInPeriod(i, bounds).map(sl => ({ ...sl, item: i })));
  const grossRevenue = periodSales.reduce((s, sl) => s + Number(sl.revenue), 0);

  // Transaction Fees: Calculate based on sales at each location
  const transactionFees = periodSales.reduce((s, sl) => {
    // Filter by location if needed
    if (pnlLocationFilter === 'all') {
      return s + Number(sl.transactionFee || 0);
    } else {
      // Only include fees for sales at the selected location
      return sl.location === pnlLocationFilter ? s + Number(sl.transactionFee || 0) : s;
    }
  }, 0);

  // Net Revenue: Revenue after transaction fees
  const netRevenue = grossRevenue - transactionFees;

  // Cost of Goods Sold: Cost of items sold in the period
  const cogs = periodSales.reduce((s, sl) => s + (Number(sl.item.cost) + Number(sl.item.labor)) * Number(sl.qty), 0);

  // Gross Profit: Net revenue minus COGS
  const grossProfit = netRevenue - cogs;

  // Operating Expenses: Recurring expenses + one-time expenses in period
  const recurringExpenses = expenses.filter(e => {
    if (e.status !== 'Active' || e.frequency === 'One-Time') return false;
    if (pnlLocationFilter === 'all') return true;
    return e.location === pnlLocationFilter;
  }).reduce((s, e) => s + expCostInPeriod(e, bounds), 0);

  const oneTimeExpenses = expenses.filter(e => {
    if (e.frequency !== 'One-Time') return false;
    if (!e.due) return false;
    const d = new Date(e.due);
    const inPeriod = d >= bounds.start && d <= bounds.end;
    if (!inPeriod) return false;
    if (pnlLocationFilter === 'all') return true;
    return e.location === pnlLocationFilter;
  }).reduce((s, e) => s + Number(e.amount), 0);

  const operatingExpenses = recurringExpenses + oneTimeExpenses;

  // Operating Income
  const operatingIncome = grossProfit - operatingExpenses;

  // Other Income/Expenses: Loan payments (negative)
  const loanPayments = loans.reduce((s,l)=>s+loanPaid(l), 0);

  // Net Income
  const netIncome = operatingIncome - loanPayments;

  return {
    grossRevenue,
    netRevenue,
    cogs,
    grossProfit,
    operatingExpenses,
    operatingIncome,
    otherIncomeExpenses: -loanPayments, // Negative for display
    netIncome,
    periodSales,
    recurringExpenses,
    oneTimeExpenses,
    transactionFees,
    loanPayments
  };
}

function renderIncomeStatement() {
  const bounds = getIncomeStatementBounds();
  const is = calculateIncomeStatement(bounds);

  // Update period label
  document.getElementById('income-statement-period').textContent = bounds.label;

  // Update main values
  document.getElementById('is-gross-revenue').textContent = fmt(is.grossRevenue);
  document.getElementById('is-transaction-fees').textContent = '−' + fmt(is.transactionFees);
  document.getElementById('is-net-revenue').textContent = fmt(is.netRevenue);
  document.getElementById('is-net-revenue').className = 'pnl-row-val ' + (is.netRevenue >= 0 ? 'pos' : 'neg');

  document.getElementById('is-cogs').textContent = '−' + fmt(is.cogs);
  document.getElementById('is-gross-profit').textContent = fmt(is.grossProfit);
  document.getElementById('is-gross-profit').className = 'pnl-row-val ' + (is.grossProfit >= 0 ? 'pos' : 'neg');

  document.getElementById('is-operating-expenses').textContent = '−' + fmt(is.operatingExpenses);
  document.getElementById('is-operating-income').textContent = fmt(is.operatingIncome);
  document.getElementById('is-operating-income').className = 'pnl-row-val ' + (is.operatingIncome >= 0 ? 'pos' : 'neg');

  // Expense breakdown
  const expenseBreakdown = [];
  if (is.recurringExpenses > 0) {
    expenseBreakdown.push(`<div class="pnl-row"><div class="pnl-row-label">Recurring Expenses</div><div class="pnl-row-val neg">−${fmt(is.recurringExpenses)}</div></div>`);
  }
  if (is.oneTimeExpenses > 0) {
    expenseBreakdown.push(`<div class="pnl-row"><div class="pnl-row-label">One-Time Expenses</div><div class="pnl-row-val neg">−${fmt(is.oneTimeExpenses)}</div></div>`);
  }
  document.getElementById('is-expense-breakdown').innerHTML = expenseBreakdown.join('');

  // Other income/expenses breakdown
  const otherBreakdown = [];
  if (is.loanPayments > 0) {
    otherBreakdown.push(`<div class="pnl-row"><div class="pnl-row-label">Loan Payments</div><div class="pnl-row-val neg">−${fmt(is.loanPayments)}</div></div>`);
  }
  document.getElementById('is-other-breakdown').innerHTML = otherBreakdown.length ? otherBreakdown.join('') : '<div class="pnl-row"><div class="pnl-row-label" style="color:var(--text3)">No other income or expenses</div></div>';

  document.getElementById('is-other-income-expenses').textContent = fmt(is.otherIncomeExpenses);
  document.getElementById('is-other-income-expenses').className = 'pnl-row-val ' + (is.otherIncomeExpenses >= 0 ? 'pos' : 'neg');

  // Net Income
  document.getElementById('is-net-income').textContent = fmt(is.netIncome);
  document.getElementById('is-net-income').className = 'pnl-row-val ' + (is.netIncome >= 0 ? 'pos' : 'neg');
}

function salesInPeriod(item, bounds) {
  return (item.sales||[]).filter(sl => {
    if (!sl.date) return false;
    const d = new Date(sl.date);
    return d >= bounds.start && d <= bounds.end;
  });
}

// ── P&L ───────────────────────────────────────────────────
function renderPnL() {
  // Check if locations are configured
  const activeLocations = locations.filter(loc => loc.active);
  const setupMsg = document.getElementById('pnl-location-setup');
  const section = document.getElementById('pnl-section');
  const lastUpdatedEl = document.getElementById('pnl-last-updated');

  if (activeLocations.length === 0) {
    if (setupMsg) setupMsg.style.display = 'block';
    if (section) section.style.display = 'none';
    if (lastUpdatedEl) lastUpdatedEl.textContent = '—';
    return;
  }

  if (setupMsg) setupMsg.style.display = 'none';
  if (section) section.style.display = 'block';

  // Populate location filter if not already done
  populatePnLLocationFilter();

  // Update last updated timestamp
  lastUpdatedEl.textContent = new Date().toLocaleString('en-US', {
    month: 'short', day: 'numeric', year: 'numeric',
    hour: 'numeric', minute: '2-digit', hour12: true
  });

  const bounds = getPeriodBounds();

  // Use global utility functions for calculations

  const inStock = getInStockItems(pnlLocationFilter);
  const totCost = inStock.reduce((a,i)=>a+(Number(i.cost)+Number(i.labor))*getItemQuantity(i, pnlLocationFilter), 0);
  const totSugg = inStock.reduce((a,i)=>a+getSuggestedPrice(i)*getItemQuantity(i, pnlLocationFilter), 0);
  const labor   = inStock.reduce((a,i)=>a+Number(i.labor)*getItemQuantity(i, pnlLocationFilter), 0);
  const raw     = inStock.reduce((a,i)=>a+Number(i.cost)*getItemQuantity(i, pnlLocationFilter), 0);
  const gross   = totSugg - totCost;
  const margin  = totSugg > 0 ? (gross/totSugg*100).toFixed(1) : 0;

  // ── Expense calculations split by type ───────────────────
  const recurringActive = expenses.filter(e => {
    if (e.status !== 'Active' || e.frequency === 'One-Time') return false;
    // Filter by location if not 'all'
    if (pnlLocationFilter === 'all') return true;
    return e.location === pnlLocationFilter;
  });

  const oneTimeActive = expenses.filter(e => {
    if (e.frequency !== 'One-Time') return false;
    // Filter by location if not 'all'
    if (pnlLocationFilter === 'all') return true;
    return e.location === pnlLocationFilter;
  });
  const monthlyExp = recurringActive.reduce((s,e)=>s+expMonthly(e), 0);

  // Recurring: count actual scheduled occurrences within the period (schedule-based)
  const recurringForPeriod = recurringActive.reduce((s,e)=>s+expCostInPeriod(e, bounds), 0);
  // Count of occurrences for display
  const recurringOccurrences = recurringActive.reduce((s,e)=>s+expOccurrencesInPeriod(e,bounds).length, 0);

  // One-time expenses whose paid date falls within the selected period
  const oneTimeInPeriod = expenses.filter(e => {
    if (e.frequency !== 'One-Time') return false;
    if (!e.due) return false;
    const d = new Date(e.due);
    return d >= bounds.start && d <= bounds.end;
  });
  const oneTimeTotal = oneTimeInPeriod.reduce((s,e)=>s+Number(e.amount), 0);

  // Total expenses for period = recurring portion + one-time items in period
  const expForPeriod = recurringForPeriod + oneTimeTotal;

  // Loan payments
  const loanPayments = loans.reduce((s,l)=>s+loanPaid(l), 0);

  // Sales filtered to selected period
  const periodSales   = inventory.flatMap(i => salesInPeriod(i, bounds).map(sl => ({ ...sl, item: i })));
  const actualUnits   = periodSales.reduce((s,sl)=>s+Number(sl.qty), 0);
  const actualRevenue = periodSales.reduce((s,sl)=>s+Number(sl.revenue), 0);
  const actualCost    = periodSales.reduce((s,sl)=>s+(Number(sl.item.cost)+Number(sl.item.labor))*Number(sl.qty), 0);
  const actualProfit  = periodSales.reduce((s,sl)=>s+Number(sl.profit), 0);
  const net           = actualProfit - expForPeriod - loanPayments;

  // By-category — period sales only, filtered by location
  const byCategory = {};
  inventory.forEach(item => {
    if (!byCategory[item.category]) byCategory[item.category] = { cost:0, sugg:0, qty:0, soldRevenue:0, soldProfit:0, soldUnits:0 };
    const d = byCategory[item.category];

    // Filter inventory quantities by location
    let itemQty = Number(item.qty);
    if (pnlLocationFilter !== 'all') {
      if (!item.inventory || !item.inventory[pnlLocationFilter]) {
        itemQty = 0;
      } else {
        itemQty = Number(item.inventory[pnlLocationFilter].qty);
      }
    }

    d.cost += (Number(item.cost)+Number(item.labor))*itemQty;
    d.sugg += getSuggestedPrice(item)*itemQty;
    d.qty  += itemQty;

  // Filter sales by period and location
  const ps = salesInPeriod(item, bounds).filter(sale => {
    if (pnlLocationFilter === 'all') return true;
    // Check if sale occurred at the selected location
    return sale.location === pnlLocationFilter;
  });

    d.soldRevenue += ps.reduce((s,sl)=>s+Number(sl.revenue), 0);
    d.soldProfit  += ps.reduce((s,sl)=>s+Number(sl.profit),  0);
    d.soldUnits   += ps.reduce((s,sl)=>s+Number(sl.qty),     0);
  });

  const locationName = pnlLocationFilter === 'all' ? 'All Locations' : (locations.find(l => l.id === pnlLocationFilter)?.name || 'Unknown Location');
  const catRows = Object.entries(byCategory)
    .filter(([, d]) => d.qty > 0 || d.soldUnits > 0)
    .sort((a,b) => a[0].localeCompare(b[0]))
    .map(([cat, d]) => {
      const projProfit = d.sugg - d.cost;
      const hasSales   = d.soldUnits > 0;
      return `<div class="pnl-row">
        <div>
          <div class="pnl-row-label">${esc(cat)}</div>
          <div style="font-size:10px;color:var(--accent);font-weight:600;margin-top:1px;">📍 ${esc(locationName)}</div>
          <div style="font-size:11px;color:var(--text3);font-family:var(--font-mono);margin-top:2px;">
            ${d.qty > 0 ? `${d.qty} in stock` : 'sold out'}
            ${hasSales ? ` · <span style="color:var(--accent2)">${d.soldUnits} sold</span>` : ''}
          </div>
        </div>
        <div style="text-align:right;">
          ${hasSales
            ? `<div style="font-family:var(--font-mono);font-size:15px;font-weight:600;color:var(--accent2)">${fmt(d.soldRevenue)}</div>
               <div style="font-size:10px;color:var(--accent2);font-family:var(--font-mono);opacity:.8">${fmt(d.soldProfit)} profit</div>`
            : `<div class="pnl-row-val ${projProfit>=0?'pos':'neg'}" style="font-size:13px;opacity:.6">${fmt(projProfit)} proj.</div>`
          }
        </div>
      </div>`;
    }).join('');

  // One-time expense rows for the breakdown card
  const oneTimeRows = oneTimeInPeriod.length > 0
    ? oneTimeInPeriod
        .sort((a,b) => new Date(a.due)-new Date(b.due))
        .map(e => `<div class="pnl-row">
          <div>
            <div class="pnl-row-label">${esc(e.name)}</div>
            <div style="font-size:11px;color:var(--text3);font-family:var(--font-mono)">${esc(e.category)} · ${e.due?new Date(e.due).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—'}</div>
          </div>
          <div class="pnl-row-val neg">−${fmt(e.amount)}</div>
        </div>`).join('')
    : '';

  const periodLabel = bounds.label;



  section.innerHTML = `
    <!-- Projected hero -->
    <div style="background:linear-gradient(135deg,rgba(26,158,110,.08),rgba(91,79,207,.06));border:1px solid rgba(26,158,110,.25);border-radius:var(--radius);padding:22px;margin-bottom:14px;text-align:center;">
      <div style="font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent2);margin-bottom:6px;">Projected Gross Profit</div>
      <div style="font-family:var(--font-mono);font-size:38px;font-weight:600;color:${gross>=0?'var(--accent2)':'var(--danger)'};">${fmtK(gross)}</div>
      <div style="font-size:13px;color:var(--text2);margin-top:5px;">If all in-stock items sell at suggested price · ${margin}% margin</div>
    </div>

    <!-- Period sales panel -->
    <div style="background:${actualRevenue>0?'linear-gradient(135deg,rgba(26,158,110,.12),rgba(26,158,110,.04))':'var(--surface)'};border:1.5px solid ${actualRevenue>0?'rgba(26,158,110,.3)':'var(--border)'};border-radius:var(--radius);padding:18px;margin-bottom:14px;">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <div style="font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:${actualRevenue>0?'var(--accent2)':'var(--text2)'};">Sales — ${esc(periodLabel)}</div>
        ${actualUnits>0?`<div style="font-size:11px;font-family:var(--font-mono);color:var(--text3)">${actualUnits} unit${actualUnits!==1?'s':''}</div>`:''}
      </div>
      ${actualRevenue>0?`
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;text-align:center;margin-bottom:14px;">
        <div>
          <div style="font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--text2);font-weight:700;margin-bottom:4px;">Revenue</div>
          <div style="font-family:var(--font-mono);font-size:20px;font-weight:600;color:var(--accent2)">${fmtK(actualRevenue)}</div>
        </div>
        <div>
          <div style="font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--text2);font-weight:700;margin-bottom:4px;">COGS</div>
          <div style="font-family:var(--font-mono);font-size:20px;font-weight:600;color:var(--accent3)">${fmtK(actualCost)}</div>
        </div>
        <div>
          <div style="font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--text2);font-weight:700;margin-bottom:4px;">Gross Profit</div>
          <div style="font-family:var(--font-mono);font-size:20px;font-weight:600;color:${actualProfit>=0?'var(--accent2)':'var(--danger)'}">${fmtK(actualProfit)}</div>
        </div>
      </div>
      <div style="font-size:11px;color:var(--text3);text-align:center;">See Expenses breakdown below for deductions → Net Profit</div>`:`
      <div style="text-align:center;padding:16px 0;color:var(--text3);font-size:13px;">No sales recorded for this period</div>`}
    </div>



    <!-- Expense breakdown for period -->
    <div class="pnl-card" style="margin-bottom:14px;">
      <div style="padding:12px 16px 8px;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);">Expenses — ${esc(periodLabel)}</div>
      ${actualRevenue>0?`
      <div class="pnl-row">
        <div class="pnl-row-label">Gross Profit (from sales)</div>
        <div class="pnl-row-val pos">${fmtK(actualProfit)}</div>
      </div>`:''}
      ${recurringActive.length>0?`
      <div class="pnl-row">
        <div>
          <div class="pnl-row-label">Recurring (${recurringActive.length} active)</div>
          <div style="font-size:11px;color:var(--text3);font-family:var(--font-mono)">${recurringOccurrences} payment${recurringOccurrences!==1?'s':''} in period · ${fmtK(monthlyExp)}/mo rate</div>
        </div>
        <div class="pnl-row-val neg">−${fmtK(recurringForPeriod)}</div>
      </div>`:''}
      ${oneTimeRows}
      ${loanPayments>0?`
      <div class="pnl-row">
        <div class="pnl-row-label">Loan Payments (all time)</div>
        <div class="pnl-row-val neg">−${fmtK(loanPayments)}</div>
      </div>`:''}
      ${oneTimeInPeriod.length===0&&recurringActive.length===0&&loanPayments===0
        ?`<div class="pnl-row"><div class="pnl-row-label" style="color:var(--text3)">No expenses recorded</div></div>`
        :`<div class="pnl-row" style="background:var(--surface2);">
            <div class="pnl-row-label" style="font-weight:700;color:var(--text);font-size:15px;">Net Profit</div>
            <div class="pnl-row-val ${net>=0?'pos':'neg'}" style="font-size:18px;">
              ${fmtK(net)}
            </div>
          </div>`
      }
    </div>

    <!-- Projected breakdown -->
    <div class="pnl-card" style="margin-bottom:14px;">
      <div style="padding:12px 16px 8px;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--text2);">Projected (all in-stock inventory)</div>
      <div class="pnl-row"><div class="pnl-row-label">Suggested Price Revenue</div><div class="pnl-row-val pos">${fmtK(totSugg)}</div></div>
      <div class="pnl-row"><div class="pnl-row-label">Raw Material Cost</div><div class="pnl-row-val neg">−${fmtK(raw)}</div></div>
      <div class="pnl-row"><div class="pnl-row-label">Total Labor Cost</div><div class="pnl-row-val neg">−${fmtK(labor)}</div></div>
      <div class="pnl-row" style="background:var(--surface2)"><div class="pnl-row-label" style="font-weight:700;color:var(--text);font-size:15px">Projected Gross Profit</div><div class="pnl-row-val ${gross>=0?'pos':'neg'}" style="font-size:18px">${fmtK(gross)}</div></div>
    </div>

    <div style="height:20px"></div>`;
}

// ═══════════════════════════════════════════════════════════
// EXPENSES
// ═══════════════════════════════════════════════════════════

let expenses = [];
let currentExpenseId = null;
// saveExpenses defined above with other API helpers

// Monthly equivalent for any frequency
function expMonthly(e) {
  if (e.frequency === 'One-Time') return 0;
  const a = Number(e.amount)||0;
  switch(e.frequency) {
    case 'Weekly':    return a * 52 / 12;
    case 'Monthly':   return a;
    case 'Quarterly': return a / 3;
    case 'Annual':    return a / 12;
    default:          return a;
  }
}
function expAnnual(e) { return expMonthly(e) * 12; }

// ── Generate scheduled occurrence dates ───────────────────
// Returns array of Dates from startDate up to `upTo` (default: today)
function expOccurrences(e, upTo) {
  if (e.frequency === 'One-Time' || !e.startDate) return [];
  const start  = new Date(e.startDate);
  const end    = upTo ? new Date(upTo) : new Date();
  const payday = Math.max(1, parseInt(e.payday)||1);
  const dates  = [];

  const clampDay = (y, m, d) => {
    const max = new Date(y, m+1, 0).getDate();
    return new Date(y, m, Math.min(d, max));
  };

  if (e.frequency === 'Weekly') {
    let cur = new Date(start);
    while (cur <= end) { dates.push(new Date(cur)); cur.setDate(cur.getDate()+7); }
  } else if (e.frequency === 'Monthly') {
    let y = start.getFullYear(), m = start.getMonth();
    while (true) {
      const d = clampDay(y, m, payday);
      if (d > end) break;
      if (d >= start) dates.push(d);
      m++; if (m > 11) { m = 0; y++; }
    }
  } else if (e.frequency === 'Quarterly') {
    let y = start.getFullYear(), m = start.getMonth();
    while (true) {
      const d = clampDay(y, m, payday);
      if (d > end) break;
      if (d >= start) dates.push(d);
      m += 3; while (m > 11) { m -= 12; y++; }
    }
  } else if (e.frequency === 'Annual') {
    const startMonth = start.getMonth();
    let y = start.getFullYear();
    while (true) {
      const d = clampDay(y, startMonth, payday);
      if (d > end) break;
      if (d >= start) dates.push(d);
      y++;
    }
  }
  return dates;
}

// Occurrences within a P&L period window
function expOccurrencesInPeriod(e, bounds) {
  if (e.frequency === 'One-Time') return [];
  return expOccurrences(e, bounds.end).filter(d => d >= bounds.start && d <= bounds.end);
}

// Total cost of a recurring expense within a period.
// If startDate is missing, fall back to rate × elapsed months so existing expenses aren't $0.
function expCostInPeriod(e, bounds) {
  if (e.frequency === 'One-Time') return 0;

  // If we have a start date, use exact schedule
  if (e.startDate) {
    const occ = expOccurrencesInPeriod(e, bounds);
    if (occ.length > 0) return occ.length * Number(e.amount||0);
    // startDate set but zero occurrences in this window — trust it (e.g. expense started after period)
    return 0;
  }

  // No startDate: fall back to proportional calculation based on period length
  const days = Math.max(1, (bounds.end - bounds.start) / 86400000);
  const months = days / 30.44; // average days per month
  return expMonthly(e) * months;
}

// YTD spend: count occurrences so far this calendar year
function expYTD(e) {
  if (e.frequency === 'One-Time') {
    if (!e.due) return 0;
    const d = new Date(e.due);
    return d.getFullYear() === new Date().getFullYear() ? Number(e.amount||0) : 0;
  }
  const ytdBounds = {
    start: new Date(new Date().getFullYear(), 0, 1),
    end:   new Date()
  };
  return expCostInPeriod(e, ytdBounds);
}

// ── Render Expenses ────────────────────────────────────────
function renderExpenses() {
  updateClock();
  const q=(document.getElementById('exp-search-box').value||'').toLowerCase();
  const active=expenses.filter(e=>e.status==='Active');
  const monthlyTotal=active.reduce((s,e)=>s+expMonthly(e),0);
  const annualTotal=active.reduce((s,e)=>s+expAnnual(e),0);
  const ytdTotal=expenses.reduce((s,e)=>s+expYTD(e),0);

  document.getElementById('exp-sum-count').textContent=expenses.length;
  document.getElementById('exp-sum-monthly').textContent=fmtK(monthlyTotal);
  document.getElementById('exp-sum-annual').textContent=fmtK(annualTotal);
  document.getElementById('exp-sum-ytd').textContent=fmtK(ytdTotal);

  const filtered=expenses
    .filter(e=>!q||e.name.toLowerCase().includes(q)||e.category.toLowerCase().includes(q))
    .sort((a,b)=>a.name.localeCompare(b.name));

  const el=document.getElementById('exp-list');
  if(!filtered.length){
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">💸</div><div class="empty-text">${q?'No expenses match':'No expenses yet'}</div><div class="empty-sub">${q?'Try a different search':'Tap + Add Expense to start tracking'}</div></div>`;
    return;
  }

  // Category color map
  const catColor={
    'Rent & Venue':'var(--danger)','Supplies':'var(--accent3)','Packaging':'var(--accent3)',
    'Marketing':'var(--accent)','Transportation':'var(--accent2)','Utilities':'var(--accent3)',
    'Software & Tools':'var(--accent)','Insurance':'var(--text2)','Other':'var(--text2)'
  };

  el.innerHTML=filtered.map(exp=>{
    const isOneTime=exp.frequency==='One-Time';
    const monthly=expMonthly(exp);
    const annual=expAnnual(exp);
    const paused=exp.status==='Paused';
    const ytd=expYTD(exp);
    const locationName = locations.find(l => l.id === exp.location)?.name || 'Unknown';
    return`<div class="inv-card" onclick="openExpenseDetail('${exp.id}')" style="${paused&&!isOneTime?'opacity:.65':''}">
      <div class="inv-card-header">
        <div style="flex:1;padding-right:10px;">
          <div class="inv-name">${esc(exp.name)}</div>
          <span class="category-chip">${esc(exp.category)}</span>
        </div>
        <div style="text-align:right;">
          <div style="font-family:var(--font-mono);font-size:16px;font-weight:700;color:var(--danger);">${fmt(exp.amount)}</div>
          <div style="font-size:10px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:${isOneTime?'var(--accent2)':paused?'var(--text3)':'var(--accent3)'};">
            ${isOneTime?'✓ One-Time':exp.frequency}
          </div>
        </div>
      </div>
      ${locationName !== 'Unknown' ? `<div style="font-size:11px;color:var(--text3);padding:0 14px 8px;margin-top:-4px;">📍 ${esc(locationName)}</div>` : ''}
      <div class="inv-metrics">
        ${isOneTime
          ?`<div class="inv-metric" style="grid-column:span 2"><div class="inv-metric-label">Date Paid</div><div class="inv-metric-value">${exp.due?new Date(exp.due).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—'}</div></div>
            <div class="inv-metric" style="grid-column:span 2"><div class="inv-metric-label">Amount</div><div class="inv-metric-value cost">${fmt(exp.amount)}</div></div>`
          :`<div class="inv-metric"><div class="inv-metric-label">Per Month</div><div class="inv-metric-value cost">${fmt(monthly)}</div></div>
            <div class="inv-metric"><div class="inv-metric-label">Per Year</div><div class="inv-metric-value cost">${fmt(annual)}</div></div>
            <div class="inv-metric"><div class="inv-metric-label">Paid YTD</div><div class="inv-metric-value highlight">${fmt(ytd)}</div></div>
            <div class="inv-metric"><div class="inv-metric-label">Status</div><div class="inv-metric-value" style="color:${paused?'var(--text3)':'var(--accent2)'};">${paused?'Paused':'Active'}</div></div>`
        }
      </div>
    </div>`;
  }).join('');
}

// ── Add/Edit Expense ───────────────────────────────────────
function updateExpenseCalc() {
  const aEl   = document.getElementById('e-amount');
  const freqEl = document.getElementById('e-frequency');
  if (!aEl || !freqEl) return;

  const a    = parseFloat(aEl.value)||0;
  const freq = freqEl.value;
  const isOneTime = freq === 'One-Time';

  // Toggle one-time vs recurring fields — guard each element
  const dueLabel  = document.getElementById('e-due-label');
  const dueInput  = document.getElementById('e-due');
  const recurFlds = document.getElementById('e-recurring-fields');
  const statusWrp = document.getElementById('e-status-wrap');
  const paydayLbl = document.getElementById('e-payday-label');

  if (dueLabel)  dueLabel.textContent = isOneTime ? 'Date Paid' : 'Next Due Date (optional)';
  if (dueInput)  dueInput.style.display = isOneTime ? 'block' : 'none';
  if (recurFlds) recurFlds.style.display = isOneTime ? 'none' : 'block';
  if (statusWrp) statusWrp.style.display = isOneTime ? 'none' : 'block';

  const paydayLabels = { Weekly:'Day of week (1=Mon)', Monthly:'Day of month', Quarterly:'Day of month', Annual:'Day of month' };
  if (paydayLbl) paydayLbl.textContent = paydayLabels[freq] || 'Payment Day';

  const dummy = { amount:a, frequency:freq };
  const mEl = document.getElementById('ec-monthly');
  const qEl = document.getElementById('ec-quarterly');
  const yEl = document.getElementById('ec-annual');
  if (mEl) mEl.textContent = fmt(expMonthly(dummy));
  if (qEl) qEl.textContent = fmt(expMonthly(dummy)*3);
  if (yEl) yEl.textContent = fmt(expAnnual(dummy));
}

function openAddExpenseModal() {
  // Check if any active locations exist
  const activeLocations = locations.filter(loc => loc.active);
  if (activeLocations.length === 0) {
    showLocationSetupMessage();
    return;
  }

  document.getElementById('exp-modal-title').textContent = 'Add Expense';
  document.getElementById('exp-edit-id').value = '';
  ['e-name','e-amount','e-notes','e-payday'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  const today = new Date().toISOString().split('T')[0];
  const catEl   = document.getElementById('e-category');   if (catEl)   catEl.value   = 'Rent & Venue';
  const freqEl  = document.getElementById('e-frequency');  if (freqEl)  freqEl.value  = 'Monthly';
  const statEl  = document.getElementById('e-status');     if (statEl)  statEl.value  = 'Active';
  const dueEl   = document.getElementById('e-due');        if (dueEl)   dueEl.value   = today;
  const startEl = document.getElementById('e-start');      if (startEl) startEl.value = today;
  const delBtn  = document.getElementById('btn-delete-expense'); if (delBtn) delBtn.style.display = 'none';
  populateExpenseLocationSelect();
  updateExpenseCalc();
  document.getElementById('modal-expense').classList.add('open');
}

function openEditExpenseModal(id) {
  const exp = expenses.find(e => e.id === id); if (!exp) return;
  const g = (elId, val) => { const el = document.getElementById(elId); if (el) el.value = (val ?? ''); };

  document.getElementById('exp-modal-title').textContent = 'Edit Expense';
  g('exp-edit-id',  id);
  g('e-name',       exp.name);
  g('e-amount',     exp.amount);
  g('e-notes',      exp.notes || '');
  g('e-due',        exp.due || '');
  g('e-start',      exp.startDate || '');
  g('e-payday',     exp.payday || '');

  const catEl  = document.getElementById('e-category');  if (catEl)  catEl.value  = exp.category  || 'Rent & Venue';
  const freqEl = document.getElementById('e-frequency'); if (freqEl) freqEl.value = exp.frequency || 'Monthly';
  const statEl = document.getElementById('e-status');    if (statEl) statEl.value = exp.status    || 'Active';

  const delBtn = document.getElementById('btn-delete-expense'); if (delBtn) delBtn.style.display = 'block';
  updateExpenseCalc();
  document.getElementById('modal-expense').classList.add('open');
}

function saveExpense() {
  const name=document.getElementById('e-name').value.trim(); if(!name){document.getElementById('e-name').focus();return;}
  const location=document.getElementById('e-location').value; if(!location){document.getElementById('e-location').focus();return;}
  const editId=document.getElementById('exp-edit-id').value;
  const existing=editId?expenses.find(e=>e.id===editId):null;
  const freq=document.getElementById('e-frequency').value;
  const isOneTime = freq === 'One-Time';
  const amount=parseFloat(document.getElementById('e-amount').value)||0;
  const due=document.getElementById('e-due').value;

  const exp={
    id:editId||uid(), name,
    category:document.getElementById('e-category').value,
    frequency:freq,
    amount,
    due,
    location,
    startDate: isOneTime ? due : (document.getElementById('e-start').value || new Date().toISOString().split('T')[0]),
    payday:    isOneTime ? null : (parseInt(document.getElementById('e-payday').value)||1),
    status: isOneTime ? 'Active' : document.getElementById('e-status').value,
    notes:document.getElementById('e-notes').value.trim(),
    payments:existing?existing.payments:[],
  };

  // For one-time: auto-record payment on save
  if (isOneTime && exp.payments.length === 0 && amount > 0) {
    exp.payments.push({ pid:uid(), date:due||new Date().toISOString().split('T')[0], amount, note:'One-time expense' });
  }
  if (isOneTime && exp.payments.length === 1 && exp.payments[0].note === 'One-time expense') {
    exp.payments[0].amount = amount;
    exp.payments[0].date   = due || exp.payments[0].date;
  }

  if(editId){const idx=expenses.findIndex(e=>e.id===editId);if(idx>-1)expenses[idx]=exp;}else expenses.unshift(exp);
  saveExpenses(); closeModal('modal-expense'); renderExpenses();
  showToast(editId?'✓ Expense updated':'✓ Expense recorded');
}

async function confirmDeleteExpense() {
  const ok=await showConfirm('Delete expense?','All payment history will be lost.'); if(!ok) return;
  const id=document.getElementById('exp-edit-id').value;
  expenses=expenses.filter(e=>e.id!==id);
  saveExpenses(); closeModal('modal-expense'); renderExpenses(); showToast('Expense deleted');
}

// ── Expense Detail ─────────────────────────────────────────
function openExpenseDetail(id) {
  currentExpenseId=id;
  renderExpenseDetail();
  document.getElementById('modal-expense-detail').classList.add('open');
}

function renderExpenseDetail() {
  const exp=expenses.find(e=>e.id===currentExpenseId); if(!exp) return;
  const isOneTime = exp.frequency === 'One-Time';
  const monthly=expMonthly(exp), annual=expAnnual(exp);
  const paused=exp.status==='Paused';

  document.getElementById('ed-name').textContent=exp.name;
  document.getElementById('ed-amount').textContent=fmt(exp.amount);
  document.getElementById('ed-frequency').textContent=exp.frequency+(exp.notes?' · '+exp.notes:'');
  document.getElementById('ed-category').textContent=exp.category;
  document.getElementById('ed-status-val').textContent=isOneTime?'✓ Recorded':(paused?'⏸ Paused':'✓ Active');
  document.getElementById('ed-status-val').style.color=isOneTime?'var(--accent2)':(paused?'var(--text3)':'var(--accent2)');
  document.getElementById('ed-hero-label').textContent = isOneTime ? 'One-Time Amount' : 'Amount per Occurrence';
  document.getElementById('ed-monthly-wrap').style.display = isOneTime ? 'none' : 'block';
  document.getElementById('ed-annual-wrap').style.display  = isOneTime ? 'none' : 'block';
  if (!isOneTime) {
    document.getElementById('ed-monthly').textContent=fmt(monthly);
    document.getElementById('ed-annual').textContent=fmt(annual);
  }
  document.getElementById('ed-recurring-section').style.display = isOneTime ? 'none' : 'block';
  document.getElementById('ed-onetime-section').style.display   = isOneTime ? 'block' : 'none';

  if (isOneTime) {
    const el = document.getElementById('ed-due');
    if (el) el.textContent = exp.due
      ? new Date(exp.due).toLocaleDateString('en-US',{weekday:'short',month:'long',day:'numeric',year:'numeric'})
      : 'Not set';
  } else {
    // Start date and payment day
    const startEl  = document.getElementById('ed-start');
    const paydayEl = document.getElementById('ed-payday');
    if (startEl) startEl.textContent = exp.startDate
      ? new Date(exp.startDate).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})
      : 'Not set';
    if (paydayEl) paydayEl.textContent = exp.payday
      ? (exp.frequency==='Weekly'
          ? ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'][Math.min(Number(exp.payday)-1,6)]
          : 'Day ' + exp.payday)
      : '—';

    // Generate schedule
    const today     = new Date();
    const past      = expOccurrences(exp, today);
    const future    = expOccurrences(exp, new Date(today.getFullYear(), today.getMonth()+4, 0)).filter(d=>d>today);
    const totalPaid = past.length * Number(exp.amount||0);

    const tl = document.getElementById('ed-total-paid-label');
    if (tl) tl.textContent = `${past.length} occurrence${past.length!==1?'s':''} · ${fmt(totalPaid)} total`;

    const recentPast  = past.slice(-3).reverse();
    const nextFuture  = future.slice(0,3);
    const scheduleEl  = document.getElementById('ed-schedule');
    if (scheduleEl) {
      const rows = [
        ...nextFuture.map(d=>`<div class="pnl-row">
          <div><div class="pnl-row-label" style="color:var(--accent3)">Upcoming</div><div style="font-size:11px;color:var(--text3);font-family:var(--font-mono)">${d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</div></div>
          <div style="font-family:var(--font-mono);font-size:14px;font-weight:600;color:var(--accent3);">${fmt(exp.amount)}</div>
        </div>`),
        ...recentPast.map(d=>`<div class="pnl-row" style="opacity:.65">
          <div><div class="pnl-row-label">Paid</div><div style="font-size:11px;color:var(--text3);font-family:var(--font-mono)">${d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</div></div>
          <div style="font-family:var(--font-mono);font-size:14px;font-weight:600;color:var(--accent2);">✓ ${fmt(exp.amount)}</div>
        </div>`),
      ];
      scheduleEl.innerHTML = rows.length
        ? rows.join('')
        : `<div class="pnl-row"><div class="pnl-row-label" style="color:var(--text3)">No occurrences yet — check start date &amp; payment day</div></div>`;
    }
  }
}

function editCurrentExpense() {
  closeModal('modal-expense-detail');
  setTimeout(()=>openEditExpenseModal(currentExpenseId),180);
}

// ── Render Loans ──────────────────────────────────────────
function renderLoans() {
  updateClock();
  const q=(document.getElementById('loan-search-box').value||'').toLowerCase();
  const tot=loans.reduce((s,l)=>s+Number(l.amount),0);
  const paid=loans.reduce((s,l)=>s+loanPaid(l),0);
  const bal=loans.reduce((s,l)=>s+loanBalance(l),0);
  document.getElementById('loan-sum-count').textContent=loans.filter(l=>l.status==='Active').length;
  document.getElementById('loan-sum-borrowed').textContent=fmtK(tot);
  document.getElementById('loan-sum-paid').textContent=fmtK(paid);
  document.getElementById('loan-sum-balance').textContent=fmtK(bal);

  const filtered=loans.filter(l=>!q||l.name.toLowerCase().includes(q)).sort((a,b)=>new Date(b.dateReceived)-new Date(a.dateReceived));
  const el=document.getElementById('loan-list');
  if(!filtered.length){el.innerHTML=`<div class="empty-state"><div class="empty-icon">🏦</div><div class="empty-text">${q?'No loans match':'No loans yet'}</div><div class="empty-sub">${q?'Try a different search':'Tap + Add Loan to get started'}</div></div>`;return;}

  el.innerHTML=filtered.map(loan=>{
    const b=loanBalance(loan),p=loanPaid(loan);
    const pct=loan.amount>0?Math.min(100,Math.round((p/Number(loan.amount))*100)):0;
    const off=loan.status==='Paid Off'||b===0;
    const sc=off?'var(--accent2)':'var(--danger)',sb=off?'#f0faf6':'#fff0f0',sbr=off?'var(--accent2)':'var(--danger)';
    return`<div class="inv-card" onclick="openLoanDetail('${loan.id}')">
      <div class="inv-card-header">
        <div style="flex:1;padding-right:10px;"><div class="inv-name">${esc(loan.name)}</div><div style="font-size:11px;color:var(--text3);font-family:var(--font-mono);margin-top:2px;">Received ${loan.dateReceived?new Date(loan.dateReceived).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—'}</div></div>
        <div style="background:${sb};border:1.5px solid ${sbr};border-radius:9px;padding:5px 11px;font-family:var(--font-mono);font-size:12px;font-weight:600;color:${sc};white-space:nowrap;">${off?'✓ Paid Off':'Active'}</div>
      </div>
      <div class="margin-bar"><div class="margin-fill" style="width:${pct}%"></div></div>
      <div class="inv-metrics">
        <div class="inv-metric"><div class="inv-metric-label">Borrowed</div><div class="inv-metric-value cost">${fmt(loan.amount)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Paid</div><div class="inv-metric-value highlight">${fmt(p)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Balance</div><div class="inv-metric-value" style="color:${sc}">${fmt(b)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">% Paid</div><div class="inv-metric-value price">${pct}%</div></div>
      </div></div>`;
  }).join('');
}

// ── Add/Edit Loan ──────────────────────────────────────────
function openAddLoanModal() {
  document.getElementById('loan-modal-title').textContent='Add Loan';
  document.getElementById('loan-edit-id').value='';
  ['l-name','l-amount','l-rate','l-notes'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('l-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('l-status').value='Active';
  document.getElementById('btn-delete-loan').style.display='none';
  updateLoanCalc(); document.getElementById('modal-loan').classList.add('open');
}
function openEditLoanModal(id) {
  const loan=loans.find(l=>l.id===id); if(!loan) return;
  document.getElementById('loan-modal-title').textContent='Edit Loan';
  document.getElementById('loan-edit-id').value=id;
  document.getElementById('l-name').value=loan.name;
  document.getElementById('l-date').value=loan.dateReceived||'';
  document.getElementById('l-amount').value=loan.amount;
  document.getElementById('l-rate').value=loan.rate||'';
  document.getElementById('l-status').value=loan.status||'Active';
  document.getElementById('l-notes').value=loan.notes||'';
  document.getElementById('btn-delete-loan').style.display='block';
  updateLoanCalc(loan); document.getElementById('modal-loan').classList.add('open');
}
function updateLoanCalc(loan) {
  const amt=parseFloat(document.getElementById('l-amount').value)||0;
  const paid=loan?loanPaid(loan):0, bal=Math.max(0,amt-paid);
  document.getElementById('lc-borrowed').textContent=fmt(amt);
  document.getElementById('lc-paid').textContent=fmt(paid);
  document.getElementById('lc-balance').textContent=fmt(bal);
  document.getElementById('lc-balance').className='calc-item-val '+(bal>0?'neg':'pos');
}
function saveLoan() {
  const name=document.getElementById('l-name').value.trim(); if(!name){document.getElementById('l-name').focus();return;}
  const editId=document.getElementById('loan-edit-id').value;
  const existing=editId?loans.find(l=>l.id===editId):null;
  const loan={id:editId||uid(),name,dateReceived:document.getElementById('l-date').value,amount:parseFloat(document.getElementById('l-amount').value)||0,rate:parseFloat(document.getElementById('l-rate').value)||0,status:document.getElementById('l-status').value,notes:document.getElementById('l-notes').value.trim(),payments:existing?existing.payments:[]};
  if(editId){const idx=loans.findIndex(l=>l.id===editId);if(idx>-1)loans[idx]=loan;}else loans.unshift(loan);
  saveLoans(); closeModal('modal-loan'); renderLoans();
  showToast(editId?'✓ Loan updated':'✓ Loan added');
}
async function confirmDeleteLoan() {
  const ok=await showConfirm('Delete loan?','All payment history will be lost.'); if(!ok) return;
  const id=document.getElementById('loan-edit-id').value;
  loans=loans.filter(l=>l.id!==id);
  saveLoans(); closeModal('modal-loan'); renderLoans(); showToast('Loan deleted');
}

// ── Loan Detail ────────────────────────────────────────────
function openLoanDetail(id) {
  currentLoanId=id;
  document.getElementById('p-date').value=new Date().toISOString().split('T')[0];
  document.getElementById('p-amount').value='';
  document.getElementById('p-note').value='';
  renderLoanDetail(); document.getElementById('modal-loan-detail').classList.add('open');
}
function renderLoanDetail() {
  const loan=loans.find(l=>l.id===currentLoanId); if(!loan) return;
  const bal=loanBalance(loan), paid=loanPaid(loan);
  const pct=loan.amount>0?Math.min(100,Math.round((paid/Number(loan.amount))*100)):0;
  const off=loan.status==='Paid Off'||bal===0;
  document.getElementById('ld-name').textContent=loan.name;
  document.getElementById('ld-balance').textContent=fmt(bal);
  document.getElementById('ld-progress').textContent=pct+'% paid off';
  document.getElementById('ld-date').textContent=loan.dateReceived?new Date(loan.dateReceived).toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'}):'—';
  document.getElementById('ld-amount').textContent=fmt(loan.amount);
  document.getElementById('ld-paid').textContent=fmt(paid);
  document.getElementById('ld-rate').textContent=(loan.rate||0)+'%';
  document.getElementById('ld-pct').textContent=pct+'%';
  document.getElementById('ld-bar').style.width=pct+'%';
  const hero=document.getElementById('ld-hero');
  hero.style.background=off?'linear-gradient(135deg,rgba(26,158,110,.08),rgba(26,158,110,.04))':'linear-gradient(135deg,rgba(201,48,48,.06),rgba(196,103,15,.04))';
  hero.style.borderColor=off?'rgba(26,158,110,.25)':'rgba(201,48,48,.2)';
  document.getElementById('ld-balance').style.color=off?'var(--accent2)':'var(--danger)';
  const ph=document.getElementById('ld-payments');
  const pmts=[...(loan.payments||[])].sort((a,b)=>new Date(b.date)-new Date(a.date));
  ph.innerHTML=!pmts.length
    ?'<div class="pnl-row"><div class="pnl-row-label" style="color:var(--text3)">No payments recorded yet</div></div>'
    :pmts.map(p=>`<div class="pnl-row"><div><div class="pnl-row-label">${esc(p.note||'Payment')}</div><div style="font-size:11px;color:var(--text3);font-family:var(--font-mono)">${p.date?new Date(p.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—'}</div></div><div style="display:flex;align-items:center;gap:10px"><div class="pnl-row-val pos">${fmt(p.amount)}</div><button onclick="removePayment('${p.pid}')" style="background:none;border:none;color:var(--text3);font-size:18px;cursor:pointer;padding:2px 6px;min-width:32px;min-height:32px">×</button></div></div>`).join('');
}

// FIX #4: cap payment at remaining balance  FIX #9: stable pid
function addPayment() {
  const loan=loans.find(l=>l.id===currentLoanId); if(!loan) return;
  let amt=parseFloat(document.getElementById('p-amount').value);
  if(!amt||amt<=0){document.getElementById('p-amount').focus();return;}
  const rem=loanBalance(loan);
  if(amt>rem){amt=rem;showToast('Capped at remaining balance');}
  if(!loan.payments)loan.payments=[];
  loan.payments.push({pid:uid(),date:document.getElementById('p-date').value,amount:amt,note:document.getElementById('p-note').value.trim()||'Payment'});
  if(loanBalance(loan)===0)loan.status='Paid Off';
  document.getElementById('p-amount').value='';
  document.getElementById('p-note').value='';
  saveLoans(); renderLoanDetail(); renderLoans(); showToast('✓ Payment recorded');
}

// FIX #9: remove by stable pid
function removePayment(pid) {
  const loan=loans.find(l=>l.id===currentLoanId); if(!loan) return;
  loan.payments=(loan.payments||[]).filter(p=>p.pid!==pid);
  if(loanBalance(loan)>0&&loan.status==='Paid Off')loan.status='Active';
  saveLoans(); renderLoanDetail(); renderLoans(); showToast('Payment removed');
}
function editCurrentLoan() { closeModal('modal-loan-detail'); setTimeout(()=>openEditLoanModal(currentLoanId),180); }

// ── Export / Import CSV ────────────────────────────────────
function exportCSV() {
  const rows=inventory.map(i=>[
    i.name, i.category, i.unit, i.qty, i.reorderPt??5,
    i.cost, i.labor,
    i.suggestedPrice??i.salePrice??0,
    i.notes||''
  ].map(v=>`"${String(v).replace(/"/g,'""')}"`).join(','));
  const csv=['Name,Category,Unit,Qty,ReorderPt,Cost,Labor,SuggestedPrice,Notes',...rows].join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download=`mobbs-enterprise-${new Date().toISOString().slice(0,10)}.csv`;
  a.click(); showToast('✓ CSV exported');
}

function importCSV(e) {
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=async ev=>{
    const lines=ev.target.result.trim().split('\n').slice(1);
    if(!lines.length){showToast('No data in file');return;}
    const ok=await showConfirm('Import CSV?',`Add ${lines.length} item(s) to inventory?`,'Import');
    if(!ok){e.target.value='';return;}
    let n=0;
    lines.forEach(line=>{
      const cols=line.match(/(".*?"|[^,]+)(?=\s*,|\s*$)/g)||[];
      const c=cols.map(v=>v.replace(/^"|"$/g,'').replace(/""/g,'"'));
      if(!c[0])return;
      // Support both new (SuggestedPrice col 7, Notes col 8) and
      // old format (InitPrice col 7, SalePrice col 8, Notes col 9)
      const isOldFormat = c.length >= 10;
      inventory.unshift({
        id:uid(),
        name:c[0]||'', category:c[1]||'Art', unit:c[2]||'piece',
        qty:parseInt(c[3])||0, reorderPt:parseInt(c[4])||5,
        cost:parseFloat(c[5])||0, labor:parseFloat(c[6])||0,
        suggestedPrice: isOldFormat ? parseFloat(c[8])||0 : parseFloat(c[7])||0,
        notes: isOldFormat ? c[9]||'' : c[8]||'',
        sales:[],
      });
      n++;
    });
    saveInventory(); renderList(); showToast(`✓ ${n} item${n!==1?'s':''} imported`);
    e.target.value='';
  };
  reader.readAsText(file);
}

// ═══════════════════════════════════════════════════════════
// REPORTS
// ═══════════════════════════════════════════════════════════
let rptPeriod = 'ytd';
const rptCharts = {};   // holds Chart.js instances so we can destroy/recreate

function setRptPeriod(p) {
  rptPeriod = p;
  document.querySelectorAll('[id^="rpt-period-"]').forEach(b=>b.classList.remove('active'));
  document.getElementById('rpt-period-'+p).classList.add('active');
  renderReports();
}

function getRptBounds() {
  const now   = new Date();
  const y     = now.getFullYear();
  const m     = now.getMonth();        // 0-based
  if (rptPeriod === 'all') {
    return { start: new Date(2000,0,1), end: now, label: 'All Time' };
  }
  if (rptPeriod === 'ytd') {
    // end = today, not Dec 31 — so we only count sales that have actually occurred
    return { start: new Date(y, 0, 1), end: now, label: `Jan 1 – Today ${y}` };
  }
  if (rptPeriod === 'month') {
    const label = now.toLocaleDateString('en-US', { month:'long', year:'numeric' });
    return { start: new Date(y, m, 1), end: now, label };
  }
  // last month
  const lm    = m === 0 ? 11 : m-1;
  const ly    = m === 0 ? y-1 : y;
  const label = new Date(ly, lm, 1).toLocaleDateString('en-US', { month:'long', year:'numeric' });
  return { start: new Date(ly, lm, 1), end: new Date(ly, lm+1, 0, 23, 59, 59), label };
}

// Get all sale events in bounds, each with item reference
function getRptSales(bounds) {
  console.log('Reports: Filtering sales for period:', bounds.label, 'from', bounds.start.toISOString(), 'to', bounds.end.toISOString());

  const allSales = inventory.flatMap(item =>
    (item.sales||[])
      .filter(sl => {
        if(!sl.date) {
          console.log('Reports: Skipping sale with no date:', sl);
          return false;
        }
        const d = parseLocalDate(sl.date);
        const inBounds = d >= bounds.start && d <= bounds.end;
        if (!inBounds) {
          console.log('Reports: Sale out of bounds:', sl.date, '->', d.toISOString());
        }
        return inBounds;
      })
      .map(sl => ({ ...sl, item }))
  );

  console.log('Reports: Found', allSales.length, 'sales in period');
  return allSales;
}

// Group sales by week or day label for the line chart
function groupSalesByTime(sales, bounds) {
  // Determine bucket size based on date range
  const days = (bounds.end - bounds.start) / 86400000;
  const isDaily = days <= 62;   // month or less → daily; else weekly

  const buckets = {};
  sales.forEach(sl => {
    const d = new Date(sl.date);
    let key;
    if (isDaily) {
      key = d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    } else {
      // ISO week number
      const dow = d.getDay(), diff = d.getDate() - dow + (dow===0?-6:1);
      const mon = new Date(d); mon.setDate(diff);
      key = 'Wk '+mon.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    }
    if (!buckets[key]) buckets[key] = { revenue:0, profit:0, fees:0 };
    buckets[key].revenue += Number(sl.revenue);
    buckets[key].profit  += Number(sl.profit);
    buckets[key].fees    += Number(sl.transactionFee || 0);
  });

  // Sort chronologically by first date seen in each bucket
  const salesSorted = [...sales].sort((a,b)=>new Date(a.date)-new Date(b.date));
  const orderedKeys = [];
  salesSorted.forEach(sl=>{
    const d = new Date(sl.date);
    let key;
    if (isDaily) {
      key = d.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    } else {
      const dow=d.getDay(), diff=d.getDate()-dow+(dow===0?-6:1);
      const mon=new Date(d); mon.setDate(diff);
      key='Wk '+mon.toLocaleDateString('en-US',{month:'short',day:'numeric'});
    }
    if (!orderedKeys.includes(key)) orderedKeys.push(key);
  });

  return {
    labels: orderedKeys,
    revenue: orderedKeys.map(k=>buckets[k].revenue),
    profit: orderedKeys.map(k=>buckets[k].profit),
    fees: orderedKeys.map(k=>buckets[k].fees)
  };
}

// Chart.js defaults — warm light palette
const CHART_COLORS = {
  green:  '#1a9e6e', greenFill: 'rgba(26,158,110,.12)',
  purple: '#5b4fcf', purpleFill:'rgba(91,79,207,.12)',
  orange: '#c4670f', orangeFill:'rgba(196,103,15,.12)',
  red:    '#c93030', redFill:   'rgba(201,48,48,.12)',
  border: '#d8d0c6', text: '#5a5248', grid: 'rgba(0,0,0,.05)',
};

function chartDefaults() {
  return {
    responsive: true, maintainAspectRatio: false,
    plugins: { legend: { labels: { color: CHART_COLORS.text, font: { family:"'DM Mono',monospace", size:10 }, boxWidth:10, padding:12 } }, tooltip: { backgroundColor:'#fff', titleColor:'#1a1612', bodyColor:'#5a5248', borderColor: CHART_COLORS.border, borderWidth:1, padding:10, titleFont:{family:"'Syne',sans-serif",weight:'700',size:12}, bodyFont:{family:"'DM Mono',monospace",size:11} } },
    scales: {
      x: { grid:{color:CHART_COLORS.grid}, ticks:{color:CHART_COLORS.text, font:{family:"'DM Mono',monospace",size:10}}, border:{color:CHART_COLORS.border} },
      y: { grid:{color:CHART_COLORS.grid}, ticks:{color:CHART_COLORS.text, font:{family:"'DM Mono',monospace",size:10}, callback: v=>'$'+(Math.abs(v)>=1000?(v/1000).toFixed(1)+'k':v.toFixed(0))}, border:{color:CHART_COLORS.border} },
    },
  };
}

function makeChart(id, config) {
  try {
    // Clean up existing chart
    if (rptCharts[id]) {
      rptCharts[id].destroy();
      delete rptCharts[id];
    }

    const ctx = document.getElementById(id);
    if (!ctx) {
      console.warn(`Chart canvas ${id} not found`);
      return;
    }

    // Create new chart with error handling
    rptCharts[id] = new Chart(ctx, config);
  } catch (error) {
    console.error(`Failed to create chart ${id}:`, error);
    // Clean up on failure
    if (rptCharts[id]) {
      try {
        rptCharts[id].destroy();
      } catch (destroyError) {
        console.error(`Failed to destroy chart ${id}:`, destroyError);
      }
      delete rptCharts[id];
    }
  }
}

function renderReports() {
  updateClock();
  const bounds = getRptBounds();
  const sales  = getRptSales(bounds);

  // ── Chart 4: Revenue vs Expenses (grouped bar) ────────────
  // This chart should always show, even with no sales data
  const expPaid = expenses.reduce((s,e)=>{
    if (e.frequency==='One-Time') {
      if(!e.due) return s;
      const d=new Date(e.due);
      return d>=bounds.start&&d<=bounds.end ? s+Number(e.amount||0) : s;
    }
    return s + expCostInPeriod(e, bounds);
  }, 0);
  const monthlyExpActive = expenses.filter(e=>e.status==='Active'&&e.frequency!=='One-Time').reduce((s,e)=>s+expMonthly(e),0);
  const expProjected = expPaid > 0 ? expPaid : monthlyExpActive; // fallback
  const loanPaidAmt  = loans.reduce((s,l)=>s+loanPaid(l),0);

   // Calculate fees paid and projected (these depend on sales/inventory data)
   const feesPaid = sales.reduce((s,sl)=>s+Number(sl.transactionFee || 0), 0);
   const inStock = getInStockItems('all');
   const feesProjected = inStock.reduce((s,i)=>{
     const primaryLocationId = getItemPrimaryLocation(i);
     const location = locations.find(l => l.id === primaryLocationId);
     const transactionFeePercent = location?.transactionFeePercent || 0;
     const projectedFee = getSuggestedPrice(i) * getItemQuantity(i, 'all') * (transactionFeePercent / 100);
     return s + projectedFee;
   }, 0);

  // Revenue and profit calculations (0 when no sales)
  const revenue = sales.reduce((s,sl)=>s+Number(sl.revenue), 0);
  const profit  = sales.reduce((s,sl)=>s+Number(sl.profit),  0);

  makeChart('chart-exp',{
    type:'bar',
    data:{
      labels:['Revenue','Profit','Exp Paid','Exp Projected','Fees Paid','Fees Projected','Loan Payments'],
      datasets:[{
        data:[revenue, profit, expPaid, expProjected, feesPaid, feesProjected, loanPaidAmt],
        backgroundColor:[CHART_COLORS.greenFill, CHART_COLORS.purpleFill, CHART_COLORS.orangeFill, CHART_COLORS.orangeFill, CHART_COLORS.redFill, CHART_COLORS.redFill, CHART_COLORS.redFill],
        borderColor:   [CHART_COLORS.green,      CHART_COLORS.purple,     CHART_COLORS.orange,     CHART_COLORS.orange,     CHART_COLORS.red,      CHART_COLORS.red,      CHART_COLORS.red],
        borderWidth:1.5, borderRadius:4,
      }],
    },
    options:{
      ...chartDefaults(),
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:ctx=>' $'+ctx.parsed.y.toFixed(2) }, backgroundColor:'#fff',titleColor:'#1a1612',bodyColor:'#5a5248',borderColor:CHART_COLORS.border,borderWidth:1 } },
    },
  });

  if (!sales.length) {
    // Clear sales-dependent charts and show empty state
    ['chart-revenue','chart-category','chart-items'].forEach(id=>{
      if(rptCharts[id]){rptCharts[id].destroy();delete rptCharts[id];}
    });

    // Show helpful empty state messages
    const emptyMsg = rptPeriod === 'all'
      ? 'No sales recorded yet — add inventory and mark items as sold to see reports'
      : `No sales in ${bounds.label.toLowerCase()} — try a different time period or add sales data`;

    // Hide charts and show empty state overlay instead of destroying canvas
    const chartContainers = ['chart-revenue','chart-category','chart-items'];
    chartContainers.forEach(id => {
      const container = document.getElementById(id)?.parentElement;
      if (container) {
        // Hide the canvas
        const canvas = document.getElementById(id);
        if (canvas) canvas.style.display = 'none';

        // Create or update empty state overlay
        let overlay = container.querySelector('.chart-empty-state');
        if (!overlay) {
          overlay = document.createElement('div');
          overlay.className = 'chart-empty-state';
          overlay.style.cssText = 'display:flex;align-items:center;justify-content:center;height:100%;color:var(--text3);font-size:13px;font-family:var(--font-main);text-align:center;padding:20px;position:absolute;top:0;left:0;right:0;bottom:0;background:var(--surface);border-radius:var(--radius);z-index:10;';
          container.style.position = 'relative';
          container.appendChild(overlay);
        }
        overlay.textContent = emptyMsg;
        overlay.style.display = 'flex';
      }
    });

    // Clear KPI values
    document.getElementById('rpt-revenue').textContent = '$0';
    document.getElementById('rpt-profit').textContent = '$0';
    document.getElementById('rpt-units').textContent = '0';
    document.getElementById('rpt-margin').textContent = '0%';

    return;
  }

  // If we have sales data, make sure charts are visible and empty states are hidden
  const chartContainers = ['chart-revenue','chart-category','chart-items'];
  chartContainers.forEach(id => {
    const container = document.getElementById(id)?.parentElement;
    if (container) {
      // Show the canvas
      const canvas = document.getElementById(id);
      if (canvas) canvas.style.display = 'block';

      // Hide empty state overlay
      const overlay = container.querySelector('.chart-empty-state');
      if (overlay) overlay.style.display = 'none';
    }
  });

  // KPIs (only calculated when there are sales)
  const fees    = sales.reduce((s,sl)=>s+Number(sl.transactionFee || 0), 0);
  const netRevenue = revenue - fees;
  const units   = sales.reduce((s,sl)=>s+Number(sl.qty),     0);
  const margin  = netRevenue>0 ? Math.round((profit/netRevenue)*100) : 0;

  document.getElementById('rpt-revenue').textContent = fmtK(revenue);
  document.getElementById('rpt-profit').textContent  = fmtK(profit);
  document.getElementById('rpt-units').textContent   = units;
  document.getElementById('rpt-margin').textContent  = margin+'%';

  // ── Chart 1: Revenue & Profit over time ──────────────────
  const timeData = groupSalesByTime(sales, bounds);
  makeChart('chart-revenue', {
    type: 'line',
    data: {
      labels: timeData.labels,
      datasets: [
        { label:'Revenue', data: timeData.revenue, borderColor: CHART_COLORS.green,  backgroundColor: CHART_COLORS.greenFill,  fill:true, tension:.35, pointRadius:3, pointBackgroundColor: CHART_COLORS.green },
        { label:'Profit',  data: timeData.profit,  borderColor: CHART_COLORS.purple, backgroundColor: CHART_COLORS.purpleFill, fill:true, tension:.35, pointRadius:3, pointBackgroundColor: CHART_COLORS.purple },
        { label:'Fees',    data: timeData.fees,    borderColor: CHART_COLORS.red,    backgroundColor: CHART_COLORS.redFill,    fill:true, tension:.35, pointRadius:3, pointBackgroundColor: CHART_COLORS.red },
      ],
    },
    options: chartDefaults(),
  });

  // ── Chart 2: Revenue by Category (donut) ─────────────────
  const byCat = {};
  sales.forEach(sl => {
    const cat = sl.item.category||'Other';
    byCat[cat] = (byCat[cat]||0) + Number(sl.revenue);
  });
  const catLabels = Object.keys(byCat).sort((a,b)=>byCat[b]-byCat[a]);
  const palette = [CHART_COLORS.green, CHART_COLORS.purple, CHART_COLORS.orange, CHART_COLORS.red, '#3b82f6','#f59e0b','#10b981','#8b5cf6','#ef4444','#06b6d4'];
  makeChart('chart-category', {
    type: 'doughnut',
    data: {
      labels: catLabels,
      datasets:[{ data: catLabels.map(k=>byCat[k]), backgroundColor: catLabels.map((_,i)=>palette[i%palette.length]), borderColor:'#fff', borderWidth:2, hoverOffset:6 }],
    },
    options: {
      responsive:true, maintainAspectRatio:false, cutout:'60%',
      plugins: {
        legend:{ position:'bottom', labels:{ color:CHART_COLORS.text, font:{family:"'DM Mono',monospace",size:10}, boxWidth:10, padding:10 } },
        tooltip:{ callbacks:{ label: ctx => ` ${ctx.label}: $${ctx.parsed.toFixed(2)}` }, backgroundColor:'#fff', titleColor:'#1a1612', bodyColor:'#5a5248', borderColor:CHART_COLORS.border, borderWidth:1 },
      },
    },
  });

  // ── Chart 3: Top items by revenue (horizontal bar) ────────
  const byItem = {};
  sales.forEach(sl => {
    const k = sl.item.name;
    if(!byItem[k]) byItem[k] = {revenue:0, profit:0};
    byItem[k].revenue += Number(sl.revenue);
    byItem[k].profit  += Number(sl.profit);
  });
  const itemsSorted = Object.entries(byItem).sort((a,b)=>b[1].revenue-a[1].revenue).slice(0,8);
  const barOpts = { ...chartDefaults(), indexAxis:'y' };
  barOpts.scales.y.ticks = { color:CHART_COLORS.text, font:{family:"'DM Mono',monospace",size:10} };
  barOpts.scales.x.ticks.callback = v=>'$'+(Math.abs(v)>=1000?(v/1000).toFixed(1)+'k':v.toFixed(0));
  makeChart('chart-items', {
    type:'bar',
    data:{
      labels: itemsSorted.map(([k])=>k.length>18?k.slice(0,16)+'…':k),
      datasets:[
        { label:'Revenue', data:itemsSorted.map(([,v])=>v.revenue), backgroundColor:CHART_COLORS.greenFill, borderColor:CHART_COLORS.green, borderWidth:1.5, borderRadius:4 },
        { label:'Profit',  data:itemsSorted.map(([,v])=>v.profit),  backgroundColor:CHART_COLORS.purpleFill, borderColor:CHART_COLORS.purple, borderWidth:1.5, borderRadius:4 },
      ],
    },
    options: barOpts,
  });
}

// ── Report Export ──────────────────────────────────────────
function exportReportCSV() {
  const bounds = getRptBounds();
  const sales  = getRptSales(bounds);
  if(!sales.length){showToast('No sales data to export');return;}

  const headers = ['Date','Item','Category','Unit','Qty','Price Each','Revenue','Cost','Profit'];
  const rows = sales
    .sort((a,b)=>new Date(a.date)-new Date(b.date))
    .map(sl=>[
      sl.date||'', sl.item.name, sl.item.category, sl.item.unit||'',
      sl.qty, sl.priceEach.toFixed(2), sl.revenue.toFixed(2),
      ((Number(sl.item.cost)+Number(sl.item.labor))*Number(sl.qty)).toFixed(2),
      sl.profit.toFixed(2),
    ].map(v=>`"${String(v).replace(/"/g,'""')}"`).join(','));

  const csv = [headers.join(','), ...rows].join('\n');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download = `mobbs-enterprise-report-${bounds.label.replace(/\s+/g,'-').toLowerCase()}-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  showToast('✓ Report CSV exported');
}

function exportReportPDF() {
  const bounds = getRptBounds();
  const sales  = getRptSales(bounds);
  const revenue= sales.reduce((s,sl)=>s+Number(sl.revenue),0);
  const profit = sales.reduce((s,sl)=>s+Number(sl.profit),0);
  const units  = sales.reduce((s,sl)=>s+Number(sl.qty),0);
  const margin = revenue>0?Math.round((profit/revenue)*100):0;

  // Category breakdown
  const byCat={};
  sales.forEach(sl=>{ const c=sl.item.category||'Other'; if(!byCat[c])byCat[c]={rev:0,pft:0,units:0}; byCat[c].rev+=Number(sl.revenue); byCat[c].pft+=Number(sl.profit); byCat[c].units+=Number(sl.qty); });
  const catTable = Object.entries(byCat).sort((a,b)=>b[1].rev-a[1].rev)
    .map(([cat,d])=>`<tr><td>${cat}</td><td>${d.units}</td><td>$${d.rev.toFixed(2)}</td><td>$${d.pft.toFixed(2)}</td><td>${d.rev>0?Math.round(d.pft/d.rev*100):0}%</td></tr>`).join('');

  // Top items
  const byItem={};
  sales.forEach(sl=>{ const k=sl.item.name; if(!byItem[k])byItem[k]={rev:0,pft:0,units:0}; byItem[k].rev+=Number(sl.revenue); byItem[k].pft+=Number(sl.profit); byItem[k].units+=Number(sl.qty); });
  const itemTable = Object.entries(byItem).sort((a,b)=>b[1].rev-a[1].rev).slice(0,10)
    .map(([name,d])=>`<tr><td>${name}</td><td>${d.units}</td><td>$${d.rev.toFixed(2)}</td><td>$${d.pft.toFixed(2)}</td></tr>`).join('');

  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Cheshire & Co Report</title>
  <style>
    body{font-family:'Helvetica Neue',Arial,sans-serif;color:#1a1612;padding:32px;max-width:720px;margin:0 auto;}
    h1{font-size:24px;font-weight:800;margin-bottom:4px;}
    .period{font-size:13px;color:#5a5248;margin-bottom:28px;}
    .kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px;}
    .kpi{background:#f5f2ee;border-radius:10px;padding:14px;text-align:center;}
    .kpi-label{font-size:9px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:#9a9080;margin-bottom:6px;}
    .kpi-val{font-size:22px;font-weight:700;color:#1a1612;}
    h2{font-size:14px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:#9a9080;margin:24px 0 10px;}
    table{width:100%;border-collapse:collapse;font-size:12px;}
    th{text-align:left;padding:8px 10px;background:#f5f2ee;font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#9a9080;}
    td{padding:9px 10px;border-bottom:1px solid #ede9e3;color:#1a1612;}
    tr:last-child td{border-bottom:none;}
    .footer{margin-top:40px;font-size:11px;color:#9a9080;text-align:center;}
  </style></head><body>
  <h1>Cheshire & Co Sales Report</h1>
  <div class="period">${bounds.label} · Generated ${new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}</div>
  <div class="kpis">
    <div class="kpi"><div class="kpi-label">Revenue</div><div class="kpi-val">$${revenue.toFixed(2)}</div></div>
    <div class="kpi"><div class="kpi-label">Profit</div><div class="kpi-val">$${profit.toFixed(2)}</div></div>
    <div class="kpi"><div class="kpi-label">Units Sold</div><div class="kpi-val">${units}</div></div>
    <div class="kpi"><div class="kpi-label">Margin</div><div class="kpi-val">${margin}%</div></div>
  </div>
  <h2>By Category</h2>
  <table><thead><tr><th>Category</th><th>Units</th><th>Revenue</th><th>Profit</th><th>Margin</th></tr></thead><tbody>${catTable||'<tr><td colspan="5" style="color:#9a9080">No data</td></tr>'}</tbody></table>
  <h2>Top Items</h2>
  <table><thead><tr><th>Item</th><th>Units</th><th>Revenue</th><th>Profit</th></tr></thead><tbody>${itemTable||'<tr><td colspan="4" style="color:#9a9080">No data</td></tr>'}</tbody></table>
  <div class="footer">Lenore's Closet · Booth Inventory &amp; Sales Tracker</div>
  </body></html>`;

  const win = window.open('','_blank');
  if(win){ win.document.write(html); win.document.close(); setTimeout(()=>win.print(),600); }
  else { showToast('Allow popups to export PDF'); }
}

// ═══════════════════════════════════════════════════════════
// BACKUP & RESTORE
// ═══════════════════════════════════════════════════════════

let _pendingRestoreData = null; // holds parsed JSON awaiting user confirm

let _cachedBackupTimestamp = null;

async function getBackupTimestamp() {
  try {
    const res = await fetch(`${API}/backup-timestamp`);
    const data = await res.json();
    _cachedBackupTimestamp = data.timestamp || null;
  } catch(e) { console.error('Get backup timestamp error', e); }
  return _cachedBackupTimestamp;
}

async function setBackupTimestamp() {
  const ts = new Date().toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit'});
  _cachedBackupTimestamp = ts;
  fetch(`${API}/backup-timestamp`, { method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify({timestamp:ts}) }).catch(e=>console.error('Set backup timestamp error',e));
  return ts;
}

async function updateBackupStatus() {
  const ts = await getBackupTimestamp();
  const label = ts ? `Last backup: ${ts}` : 'Last backup: never — back up now!';
  const color = ts ? 'var(--text3)' : 'var(--danger)';
  const statusEl = document.getElementById('backup-status');
  const dateEl   = document.getElementById('backup-date');
  if (statusEl) { statusEl.style.display = 'block'; statusEl.style.color = color; }
  if (dateEl)   dateEl.textContent = ts || 'never';
}

async function openBackupModal() {
  // Populate counts
  const salesCount = inventory.reduce((s,i)=>s+(i.sales||[]).length, 0);
  const g = (id, val) => { const el=document.getElementById(id); if(el) el.textContent=val; };
  g('bk-inv-count',   inventory.length);
  g('bk-exp-count',   expenses.length);
  g('bk-loan-count',  loans.length);
  g('bk-sales-count', salesCount);

  const ts = await getBackupTimestamp();
  const lastEl = document.getElementById('bk-last-backup');
  if (lastEl) lastEl.textContent = ts ? `Last backup: ${ts}` : 'Last backup: never';

  // Hide restore preview
  const prev = document.getElementById('bk-preview');
  if (prev) prev.style.display = 'none';
  _pendingRestoreData = null;

  document.getElementById('modal-backup').classList.add('open');
}

async function downloadBackup() {
  const backup = {
    version: 2,
    exportedAt: new Date().toISOString(),
    inventory,
    expenses,
    loans,
  };

  const json = JSON.stringify(backup, null, 2);
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([json], {type:'application/json'}));
  const date = new Date().toISOString().slice(0,10);
  a.download = `mobbs-enterprise-backup-${date}.json`;
  a.click();

  const ts = await setBackupTimestamp();
  const lastEl = document.getElementById('bk-last-backup');
  if (lastEl) lastEl.textContent = `Last backup: ${ts}`;
  updateBackupStatus();
  showToast('✓ Backup downloaded');
}

function restoreBackup(e) {
  const file = e.target.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    try {
      const data = JSON.parse(ev.target.result);

      // Validate structure
      if (!data.inventory || !Array.isArray(data.inventory)) {
        showToast('⚠ Invalid backup file'); e.target.value=''; return;
      }

      _pendingRestoreData = data;

      // Show preview
      const salesCount = (data.inventory||[]).reduce((s,i)=>s+(i.sales||[]).length, 0);
      const expDate = data.exportedAt
        ? new Date(data.exportedAt).toLocaleString('en-US',{month:'short',day:'numeric',year:'numeric',hour:'numeric',minute:'2-digit'})
        : 'Unknown date';

      const previewEl = document.getElementById('bk-preview-content');
      if (previewEl) previewEl.innerHTML = `
        <div class="pnl-row"><div class="pnl-row-label">Backup date</div><div style="font-family:var(--font-mono);font-size:13px;color:var(--text2)">${expDate}</div></div>
        <div class="pnl-row"><div class="pnl-row-label">Inventory items</div><div class="pnl-row-val">${(data.inventory||[]).length}</div></div>
        <div class="pnl-row"><div class="pnl-row-label">Sales records</div><div class="pnl-row-val">${salesCount}</div></div>
        <div class="pnl-row"><div class="pnl-row-label">Expenses</div><div class="pnl-row-val">${(data.expenses||[]).length}</div></div>
        <div class="pnl-row"><div class="pnl-row-label">Loans</div><div class="pnl-row-val">${(data.loans||[]).length}</div></div>
      `;

      const prev = document.getElementById('bk-preview');
      if (prev) prev.style.display = 'block';

    } catch {
      showToast('⚠ Could not read backup file');
    }
    e.target.value = '';
  };
  reader.readAsText(file);
}

async function confirmRestore() {
  if (!_pendingRestoreData) return;

  const ok = await showConfirm(
    'Replace all data?',
    'This will overwrite your current inventory, expenses, and loans with the backup. This cannot be undone.',
    'Restore'
  );
  if (!ok) return;

  // Apply the backup
  inventory = _pendingRestoreData.inventory || [];
  expenses  = _pendingRestoreData.expenses  || [];
  loans     = _pendingRestoreData.loans     || [];

  saveInventory();
  saveExpenses();
  saveLoans();

  _pendingRestoreData = null;
  closeModal('modal-backup');
  renderList();
  updateBackupStatus();
  showToast('✓ Data restored from backup');
}

async function deleteAllData() {
  const ok = await showConfirm(
    'Delete all data?',
    'This will permanently remove all inventory, sales, expenses, and loans from the server. Download a backup first. This cannot be undone.',
    'Delete Everything'
  );
  if (!ok) return;

  try {
    showToast('Deleting…');
    const res = await fetch(`${API}/reset`, { method: 'DELETE' });
    if (!res.ok) throw new Error(`Server error ${res.status}`);

    // Reset in-memory state
    inventory = [];
    expenses  = [];
    loans     = [];

    closeModal('modal-backup');
    renderList();
    showToast('✓ All data deleted from server');
  } catch (err) {
    console.error('Delete all error:', err);
    showToast('⚠ Delete failed — check connection');
  }
}

// ── Reset Inventory ──────────────────────────────────────────
function openResetInventoryModal() {
  // Populate location checkboxes
  const locationOptionsEl = document.getElementById('reset-location-options');
  const activeLocations = locations.filter(loc => loc.active);

  if (activeLocations.length === 0) {
    locationOptionsEl.innerHTML = '<div style="grid-column:span 2;text-align:center;padding:20px;color:var(--text3);font-size:14px;">No active locations configured</div>';
    document.getElementById('reset-confirm-btn').disabled = true;
    document.getElementById('modal-reset-inventory').classList.add('open');
    return;
  }

  locationOptionsEl.innerHTML = activeLocations.map(loc => `
    <label style="display:flex;align-items:center;gap:8px;padding:12px;background:var(--surface);border:1px solid var(--border);border-radius:8px;cursor:pointer;">
      <input type="checkbox" class="location-checkbox" value="${loc.id}" onchange="updateResetPreview()" style="width:16px;height:16px;">
      <div style="flex:1;">
        <div style="font-size:14px;font-weight:600;color:var(--text);">${esc(loc.name)}</div>
        <div style="font-size:11px;color:var(--text3);">${loc.type === 'storage' ? 'Storage' : 'Retail Booth'}${loc.isWarehouse ? ' · 🏭 Warehouse' : ''}</div>
      </div>
    </label>
  `).join('');

  // Reset checkboxes and options
  document.getElementById('reset-all-locations').checked = false;
  document.getElementById('reset-only-zero-stock').checked = false;
  document.getElementById('reset-preview').style.display = 'none';
  document.getElementById('reset-confirm-btn').disabled = true;

  document.getElementById('modal-reset-inventory').classList.add('open');
}

function toggleAllLocations() {
  const allCheckbox = document.getElementById('reset-all-locations');
  const locationCheckboxes = document.querySelectorAll('.location-checkbox');

  locationCheckboxes.forEach(checkbox => {
    checkbox.checked = allCheckbox.checked;
  });

  updateResetPreview();
}

function updateResetPreview() {
  const selectedLocations = Array.from(document.querySelectorAll('.location-checkbox:checked')).map(cb => cb.value);
  const onlyZeroStock = document.getElementById('reset-only-zero-stock').checked;
  const resetItemsSold = document.getElementById('reset-items-sold').checked;

  if (selectedLocations.length === 0 && !resetItemsSold) {
    document.getElementById('reset-preview').style.display = 'none';
    document.getElementById('reset-confirm-btn').disabled = true;
    return;
  }

  // Calculate what will be reset
  let itemsToReset = [];
  let totalUnitsToReset = 0;
  let totalSalesRecords = 0;
  let totalRevenueLost = 0;

  inventory.forEach(item => {
    if (!item.inventory) return;

    selectedLocations.forEach(locationId => {
      const locationQty = Number(item.inventory[locationId]?.qty || 0);
      if (!onlyZeroStock || locationQty === 0) {
        itemsToReset.push({
          itemId: item.id,
          itemName: item.name,
          locationId: locationId,
          locationName: locations.find(l => l.id === locationId)?.name || locationId,
          currentQty: locationQty
        });
        totalUnitsToReset += locationQty;
      }
    });
  });

  // Calculate sales impact if reset items sold is checked
  if (resetItemsSold) {
    inventory.forEach(item => {
      if (item.sales && item.sales.length > 0) {
        // If locations are selected, only count sales from those locations
        let salesToCount = item.sales;
        if (selectedLocations.length > 0) {
          salesToCount = item.sales.filter(sale => selectedLocations.includes(sale.location));
        }

        totalSalesRecords += salesToCount.length;
        totalRevenueLost += salesToCount.reduce((sum, sale) => sum + Number(sale.revenue || 0), 0);
      }
    });
  }

  // Show preview
  const previewContentEl = document.getElementById('reset-preview-content');
  const hasInventoryChanges = itemsToReset.length > 0;
  const hasSalesChanges = resetItemsSold && totalSalesRecords > 0;

  if (!hasInventoryChanges && !hasSalesChanges) {
    previewContentEl.innerHTML = '<div style="text-align:center;color:var(--text3);font-size:13px;padding:10px;">No items match the selected criteria</div>';
  } else {
    let previewHTML = '';

    if (hasInventoryChanges) {
      previewHTML += `
        <div class="pnl-row"><div class="pnl-row-label">Items affected</div><div class="pnl-row-val">${itemsToReset.length}</div></div>
        <div class="pnl-row"><div class="pnl-row-label">Total units to reset</div><div class="pnl-row-val">${totalUnitsToReset}</div></div>
      `;
    }

    if (hasSalesChanges) {
      previewHTML += `
        <div class="pnl-row"><div class="pnl-row-label">Sales records to remove</div><div class="pnl-row-val">${totalSalesRecords}</div></div>
        <div class="pnl-row"><div class="pnl-row-label">Revenue history lost</div><div class="pnl-row-val">$${totalRevenueLost.toFixed(2)}</div></div>
      `;
    }

    const actionDescription = [];
    if (hasInventoryChanges) {
      actionDescription.push('set inventory quantities to zero');
    }
    if (hasSalesChanges) {
      actionDescription.push('clear all sales history');
    }

    previewHTML += `
      <div style="margin-top:12px;font-size:11px;color:var(--text3);line-height:1.5;">
        This will ${actionDescription.join(' and ')} for the selected items${selectedLocations.length > 0 ? ' at the chosen locations' : ''}. This cannot be undone.
      </div>
    `;

    previewContentEl.innerHTML = previewHTML;
  }

  document.getElementById('reset-preview').style.display = 'block';
  document.getElementById('reset-confirm-btn').disabled = !hasInventoryChanges && !hasSalesChanges;
}

async function confirmResetInventory() {
  const selectedLocations = Array.from(document.querySelectorAll('.location-checkbox:checked')).map(cb => cb.value);
  const onlyZeroStock = document.getElementById('reset-only-zero-stock').checked;
  const resetItemsSold = document.getElementById('reset-items-sold').checked;

  if (selectedLocations.length === 0 && !resetItemsSold) {
    showToast('Select at least one location or check "Reset items sold"');
    return;
  }

  // Count affected items and sales
  let affectedItems = 0;
  let affectedUnits = 0;
  let affectedSalesRecords = 0;
  let affectedRevenue = 0;

  inventory.forEach(item => {
    if (!item.inventory) return;
    selectedLocations.forEach(locationId => {
      const qty = Number(item.inventory[locationId]?.qty || 0);
      if (!onlyZeroStock || qty === 0) {
        affectedItems++;
        affectedUnits += qty;
      }
    });
  });

  // Count sales impact
  if (resetItemsSold) {
    inventory.forEach(item => {
      if (item.sales && item.sales.length > 0) {
        let salesToCount = item.sales;
        if (selectedLocations.length > 0) {
          salesToCount = item.sales.filter(sale => selectedLocations.includes(sale.location));
        }
        affectedSalesRecords += salesToCount.length;
        affectedRevenue += salesToCount.reduce((sum, sale) => sum + Number(sale.revenue || 0), 0);
      }
    });
  }

  if (affectedItems === 0 && affectedSalesRecords === 0) {
    showToast('No items match the selected criteria');
    return;
  }

  // Build confirmation message
  let confirmMsg = '';
  const actions = [];

  if (affectedItems > 0) {
    const locationNames = selectedLocations.map(id => locations.find(l => l.id === id)?.name || id).join(', ');
    actions.push(`reset ${affectedUnits} units across ${affectedItems} item${affectedItems !== 1 ? 's' : ''} at: ${locationNames}`);
  }

  if (affectedSalesRecords > 0) {
    actions.push(`clear ${affectedSalesRecords} sales record${affectedSalesRecords !== 1 ? 's' : ''} ($${affectedRevenue.toFixed(2)} revenue)`);
  }

  confirmMsg = `${actions.join(' and ')}? This cannot be undone.`;

  const ok = await showConfirm('Reset Inventory?', confirmMsg, 'Reset');
  if (!ok) return;

  // Perform the reset
  try {
    showToast('Resetting inventory…');

    // Update inventory in memory
    if (affectedItems > 0) {
      inventory.forEach(item => {
        if (!item.inventory) return;
        selectedLocations.forEach(locationId => {
          const currentQty = Number(item.inventory[locationId]?.qty || 0);
          if (!onlyZeroStock || currentQty === 0) {
            item.inventory[locationId] = {
              qty: 0,
              lastUpdated: new Date().toISOString()
            };
          }
        });
      });
    }

    // Clear sales history if requested
    if (resetItemsSold) {
      inventory.forEach(item => {
        if (item.sales && item.sales.length > 0) {
          if (selectedLocations.length === 0) {
            // Clear all sales if no locations selected
            item.sales = [];
          } else {
            // Clear only sales from selected locations
            item.sales = item.sales.filter(sale => !selectedLocations.includes(sale.location));
          }
        }
      });
    }

    // Save to server
    await saveInventory();

    // Close modal and refresh display
    closeModal('modal-reset-inventory');
    renderList();

    // Build success message
    const successActions = [];
    if (affectedItems > 0) {
      successActions.push(`reset ${affectedUnits} units across ${affectedItems} item${affectedItems !== 1 ? 's' : ''}`);
    }
    if (affectedSalesRecords > 0) {
      successActions.push(`cleared ${affectedSalesRecords} sales record${affectedSalesRecords !== 1 ? 's' : ''}`);
    }

    showToast(`✓ ${successActions.join(' and ')}`);

  } catch (error) {
    console.error('Reset inventory error:', error);
    showToast('⚠ Reset failed — check connection');
  }
}

