// ── Reprocess Images for Orientation Fix ────────────────────
async function reprocessImages() {
  const ok = await showConfirm(
    'Fix Image Orientation?',
    'This will reprocess all existing images to correct portrait orientation issues from iPhone photos. This may take a few minutes depending on the number of images.',
    'Start Reprocessing'
  );

  if (!ok) return;

  try {
    showToast('🔄 Starting image reprocessing…');

    // Get all items with images
    const itemsWithImages = inventory.filter(item => item.imageId);
    if (itemsWithImages.length === 0) {
      showToast('No images found to reprocess');
      return;
    }

    let successCount = 0;
    let errorCount = 0;

    // Process images in batches to avoid overwhelming the server
    const batchSize = 5;
    for (let i = 0; i < itemsWithImages.length; i += batchSize) {
      const batch = itemsWithImages.slice(i, i + batchSize);

      // Process batch concurrently
      const promises = batch.map(async (item) => {
        try {
          const response = await fetch(`${API}/images?action=reprocess&id=${item.imageId}`, {
            method: 'POST'
          });

          if (response.ok) {
            successCount++;
            console.log(`✅ Reprocessed image for ${item.name}`);
          } else {
            const error = await response.json();
            console.error(`❌ Failed to reprocess image for ${item.name}:`, error.details || error.error);
            errorCount++;
          }
        } catch (error) {
          console.error(`❌ Network error reprocessing image for ${item.name}:`, error);
          errorCount++;
        }
      });

      await Promise.all(promises);

      // Update progress
      const processed = Math.min(i + batchSize, itemsWithImages.length);
      showToast(`🔄 Reprocessing images... ${processed}/${itemsWithImages.length} completed`);

      // Small delay between batches to be gentle on the server
      if (i + batchSize < itemsWithImages.length) {
        await new Promise(resolve => setTimeout(resolve, 1000));
      }
    }

    // Final status
    if (errorCount === 0) {
      showToast(`✅ Successfully reprocessed ${successCount} image${successCount !== 1 ? 's' : ''}`);
    } else {
      showToast(`⚠️ Reprocessed ${successCount} image${successCount !== 1 ? 's' : ''}, ${errorCount} failed`);
    }

    // Refresh the inventory display to show updated images
    renderList();

  } catch (error) {
    console.error('Image reprocessing error:', error);
    showToast('⚠️ Image reprocessing failed — check console for details');
  }
}

let selectedItems = {}; // itemId → qty (Move From is auto-detected per item)

function openMoveInventoryModal() {
  const activeLocations = locations.filter(loc => loc.active);
  if (activeLocations.length < 2) {
    showToast('Need at least 2 active locations to move inventory');
    return;
  }

  selectedItems = {};

  const destSelect = document.getElementById('move-destination');
  destSelect.innerHTML = '<option value="">Select destination…</option>';

  activeLocations.forEach(loc => {
    const option = document.createElement('option');
    option.value = loc.id;
    option.textContent = loc.name;
    destSelect.appendChild(option);
  });

  document.getElementById('modal-move-inventory').classList.add('open');
  updateMoveList();
}

function updateMoveList() {
  const destination = document.getElementById('move-destination').value;
  const listEl = document.getElementById('move-inventory-list');
  const summaryEl = document.getElementById('move-summary');
  const moveBtn = document.getElementById('move-btn');

  if (!destination) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text3);font-size:14px;">Select a destination location above</div>';
    summaryEl.style.display = 'none';
    moveBtn.disabled = true;
    return;
  }

  // Only items that have inventory OUTSIDE the selected destination
  const availableItems = inventory.filter(item => {
    if (!item.inventory) return false;
    return Object.keys(item.inventory).some(locId => {
      return locId !== destination && Number(item.inventory[locId]?.qty || 0) > 0;
    });
  });

  if (!availableItems.length) {
    listEl.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text3);font-size:14px;">No items available to move to this location</div>';
    summaryEl.style.display = 'none';
    moveBtn.disabled = true;
    return;
  }

  listEl.innerHTML = availableItems.map(item => {
    // Auto-calculate available qty (excluding destination)
    const availableQty = Object.keys(item.inventory || {})
      .filter(locId => locId !== destination)
      .reduce((sum, locId) => sum + Number(item.inventory[locId].qty || 0), 0);

    const selectedQty = selectedItems[item.id] || 0;

    return `<div class="inv-card" style="margin-bottom:12px;padding:12px;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <div style="flex:1;">
          <div class="inv-name" style="font-weight:600;">${esc(item.name)}</div>
          <span class="category-chip">${esc(item.category)}</span>
          <div style="font-size:12px;color:var(--text3);margin-top:4px;">
            Available to move: <strong>${availableQty}</strong> ${esc(item.unit || 'units')}
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:8px;margin-left:12px;">
          <input type="number" class="form-input" style="width:78px;" 
                 id="move-qty-${item.id}" value="${selectedQty}" min="0" max="${availableQty}" 
                 onchange="updateItemSelection('${item.id}', this.value)">
          <input type="checkbox" id="move-check-${item.id}" ${selectedQty > 0 ? 'checked' : ''} 
                 onchange="toggleItemSelection('${item.id}')">
        </div>
      </div>
    </div>`;
  }).join('');

  updateMoveSummary();
}

function toggleItemSelection(itemId) {
  const checkbox = document.getElementById(`move-check-${itemId}`);
  const qtyInput = document.getElementById(`move-qty-${itemId}`);
  if (checkbox.checked) {
    const max = parseInt(qtyInput.getAttribute('max')) || 1;
    qtyInput.value = Math.min(1, max);
    updateItemSelection(itemId, qtyInput.value);
  } else {
    qtyInput.value = 0;
    updateItemSelection(itemId, 0);
  }
}

function updateItemSelection(itemId, qty) {
  const quantity = parseInt(qty) || 0;
  const checkbox = document.getElementById(`move-check-${itemId}`);
  const maxQty = parseInt(document.getElementById(`move-qty-${itemId}`).getAttribute('max')) || 0;

  if (quantity > maxQty) {
    showToast(`Cannot move more than ${maxQty} units`);
    document.getElementById(`move-qty-${itemId}`).value = maxQty;
    selectedItems[itemId] = maxQty;
  } else if (quantity > 0) {
    selectedItems[itemId] = quantity;
    checkbox.checked = true;
  } else {
    delete selectedItems[itemId];
    checkbox.checked = false;
  }
  updateMoveSummary();
}

function updateMoveSummary() {
  const summaryEl = document.getElementById('move-summary');
  const contentEl = document.getElementById('move-summary-content');
  const btn = document.getElementById('move-btn');

  const count = Object.keys(selectedItems).length;
  const total = Object.values(selectedItems).reduce((a, b) => a + b, 0);

  if (count > 0) {
    const destName = locations.find(l => l.id === document.getElementById('move-destination').value)?.name || '';
    contentEl.innerHTML = `
      <div style="display:flex;justify-content:space-between;margin-bottom:4px;">
        <div>Items selected</div><div><strong>${count}</strong></div>
      </div>
      <div style="display:flex;justify-content:space-between;">
        <div>Total units</div><div><strong>${total}</strong></div>
      </div>
      <div style="margin-top:8px;font-size:13px;">To: <strong>${esc(destName)}</strong></div>
    `;
    summaryEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = `Move ${total} Unit${total !== 1 ? 's' : ''}`;
  } else {
    summaryEl.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Move Selected Items';
  }
}

async function executeMove() {
  const destination = document.getElementById('move-destination').value;
  if (!destination) return;

  const selectedItemIds = Object.keys(selectedItems);
  if (selectedItemIds.length === 0) return;

  const moveBtn = document.getElementById('move-btn');
  const originalText = moveBtn.textContent;
  moveBtn.disabled = true;
  moveBtn.textContent = 'Moving…';

  try {
    let success = 0;
    let failed = 0;

    for (const itemId of selectedItemIds) {
      const quantity = selectedItems[itemId];
      const item = inventory.find(i => i.id === itemId);
      if (!item || !item.inventory) { failed++; continue; }

      // Automatically identify Move From location (highest qty outside destination)
      let fromLocation = null;
      let maxQty = 0;
      Object.keys(item.inventory).forEach(locId => {
        if (locId === destination) return;
        const qty = Number(item.inventory[locId].qty || 0);
        if (qty > maxQty) {
          maxQty = qty;
          fromLocation = locId;
        }
      });

      if (!fromLocation || maxQty < quantity) { failed++; continue; }

      const response = await fetch(`${API}/inventory?action=transfer`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          itemId,
          fromLocation,
          toLocation: destination,
          quantity
        })
      });

      if (response.ok) success++;
      else failed++;
    }

    await loadAllData();
    renderList();
    closeModal('modal-move-inventory');
    showToast(`✅ Moved ${success} item${success !== 1 ? 's' : ''}${failed ? ` (${failed} failed)` : ''}`);

  } catch (e) {
    console.error(e);
    showToast('Move failed – check console');
  } finally {
    moveBtn.disabled = false;
    moveBtn.textContent = originalText;
  }
}

function saveDetailNotes() {
  const currentDetailId = window.currentDetailId || window.currentEditId;
  if (!currentDetailId) {
    showToast('No item selected');
    return;
  }
  const textarea = document.getElementById('detail-notes-edit');
  const notes = textarea ? textarea.value.trim() : '';

  fetch('/.netlify/functions/inventory?action=updateNotes', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ itemId: currentDetailId, notes })
  })
  .then(res => res.json())
  .then(data => {
    if (data.success || data.updated) {
      const item = items.find(i => i.id === currentDetailId);
      if (item) item.notes = notes;
      if (typeof renderList === 'function') renderList();
      showToast('Notes saved successfully');
      if (typeof closeModal === 'function') closeModal('modal-detail');
    } else {
      showToast('Failed to save notes');
    }
  })
  .catch(err => {
    console.error('saveDetailNotes error:', err);
    showToast('Failed to save notes');
  });
}

// ── Init ───────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', async () => {
  ['modal-add','modal-detail','modal-loan','modal-loan-detail','modal-expense','modal-expense-detail','modal-backup','modal-move-inventory','modal-location-edit'].forEach(initSwipeDismiss);
  populateUnitSelect('print');
  await loadAllData();
  populateInventoryLocationFilter();
  renderList();
  updateBackupStatus();
  // Initialize Finance view to show Income Statement by default
  document.getElementById('finance-view-selector').value = 'income-statement';
  setFinanceView();
});
