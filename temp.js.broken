'use strict';

// ── Utilities ──────────────────────────────────────────────
function uid() { return Date.now().toString(36) + Math.random().toString(36).slice(2,6); }
// FIX #12: sanitize all user content before innerHTML insertion
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmt(n)  { return '$' + parseFloat(n||0).toFixed(2); }
function fmtK(n) { n=parseFloat(n||0); return Math.abs(n)>=1000 ? '$'+(n/1000).toFixed(1)+'k' : fmt(n); }

// ── Toast (FIX #14) ────────────────────────────────────────
let _tt;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg; el.classList.add('show');
  clearTimeout(_tt); _tt = setTimeout(() => el.classList.remove('show'), 2400);
}

// ── Confirm dialog (FIX #2) ───────────────────────────────
let _cr = null;
function showConfirm(title, msg, okLabel='Delete') {
  return new Promise(res => {
    _cr = res;
    document.getElementById('confirm-title').textContent  = title;
    document.getElementById('confirm-msg').textContent    = msg;
    document.getElementById('confirm-ok-btn').textContent = okLabel;
    document.getElementById('confirm-overlay').classList.add('open');
  });
}
function confirmResolve(v) {
  document.getElementById('confirm-overlay').classList.remove('open');
  if (_cr) { _cr(v); _cr = null; }
}

// ── Clock (FIX #13) ───────────────────────────────────────
function updateClock() {
  const now  = new Date();
  const time = now.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',hour12:true});
  const date = now.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
  ['clock-time','pnl-clock','loans-clock','exp-clock','rpt-clock','settings-clock'].forEach(id => { const e=document.getElementById(id); if(e) e.textContent=time; });
  ['clock-date','pnl-date','loans-date','exp-date','rpt-date','settings-date'].forEach(id => { const e=document.getElementById(id); if(e) e.textContent=date; });
}
updateClock();
setInterval(updateClock, 10000);

// ── Install Banner ─────────────────────────────────────────
const isStandalone = window.navigator.standalone===true || window.matchMedia('(display-mode:standalone)').matches;
if (/iphone|ipad|ipod/i.test(navigator.userAgent) && /^((?!chrome|android).)*safari/i.test(navigator.userAgent)
    && !isStandalone && localStorage.getItem('sp_banner')!=='1')
  document.getElementById('install-banner').classList.add('show');
function dismissBanner() { document.getElementById('install-banner').classList.remove('show'); localStorage.setItem('sp_banner','1'); }

