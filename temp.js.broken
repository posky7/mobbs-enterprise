  renderIndividualSales();
}

function setIndividualSalesPeriod(period) {
  individualSalesPeriod = period;

  // Update button states
  document.querySelectorAll('[id^="individual-sales-period-"]').forEach(btn => {
    btn.classList.remove('active');
  });
