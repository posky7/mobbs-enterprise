// ── Global Utility Functions ──────────────────────────────────
// Shared calculation utilities for P&L and Reports
function getSuggestedPrice(item) {
  return Number(item.suggestedPrice ?? item.salePrice ?? 0);
}

// Parse YYYY-MM-DD date string as local midnight (not UTC midnight)
function parseLocalDate(dateString) {
  if (!dateString) return null;
  // Split YYYY-MM-DD and create date at local midnight
  const [year, month, day] = dateString.split('-').map(Number);
  return new Date(year, month - 1, day); // month is 0-based in Date constructor
}

function getItemQuantity(item, locationFilter) {
  if (locationFilter === 'all') return Number(item.totalQty || 0);
  return item.inventory && item.inventory[locationFilter] ? Number(item.inventory[locationFilter].qty) : 0;
}

function getInStockItems(locationFilter) {
  return inventory.filter(i => {
    if (locationFilter === 'all') return Number(i.totalQty || 0) > 0;
    // For specific location, check if item has inventory at that location with qty > 0
    return i.inventory && i.inventory[locationFilter] && Number(i.inventory[locationFilter].qty) > 0;
  });
}

function filterItemsByLocation(items, locationFilter) {
  if (locationFilter === 'all') return items;
  return items.filter(item => {
    if (!item.inventory) return false;
    return item.inventory[locationFilter] && Number(item.inventory[locationFilter].qty) > 0;
  });
}

function filterSalesByLocation(sales, locationFilter) {
  if (locationFilter === 'all') return sales;
  return sales.filter(sale => {
    // Find the item and check if it has inventory at the selected location
    const item = inventory.find(i => i.id === sale.item.id);
    if (!item || !item.inventory) return false;
    return item.inventory[locationFilter] && Number(item.inventory[locationFilter].qty) >= 0;
  });
}

function calculateProjectedFees(inventory, locationFilter) {
  const inStock = getInStockItems(locationFilter);
  return inStock.reduce((s, i) => {
    const primaryLocationId = getItemPrimaryLocation(i);
    const location = locations.find(l => l.id === primaryLocationId);
    const transactionFeePercent = location?.transactionFeePercent || 0;
    const projectedFee = getSuggestedPrice(i) * getItemQuantity(i, locationFilter) * (transactionFeePercent / 100);
    return s + projectedFee;
  }, 0);
}

// ── Hunt Functions ───────────────────────────────────────────
async function loadHuntItems() {
  try {
    const response = await fetchWithRetry(`${API}/hunt`);
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    huntItems = await response.json();
    console.log('Loaded', huntItems.length, 'hunt items');
  } catch (error) {
    console.error('Failed to load hunt items:', error);
    huntItems = [];
    showToast('⚠ Failed to load hunt items');
  }
}

async function saveHuntItems() {
  try {
    const response = await fetchWithRetry(`${API}/hunt`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(huntItems)
    });
    if (!response.ok) throw new Error(`HTTP ${response.status}`);
    console.log('Saved', huntItems.length, 'hunt items');
  } catch (error) {
    console.error('Failed to save hunt items:', error);
    showToast('⚠ Failed to save hunt items');
    throw error;
  }
}

function setHuntCategoryFilter(category) {
  huntCategoryFilter = category;

  // Update active tab styling
  document.querySelectorAll('#hunt-category-tabs .category-tab').forEach(tab => {
    tab.classList.remove('active');
  });
  document.querySelector(`#hunt-category-tabs .category-tab[onclick*="${category}"]`)?.classList.add('active');

  renderHunt();
}

function renderHunt() {
  const container = document.getElementById('hunt-list');
  if (!container) return;

  // Filter items by category
  let filteredItems = huntItems;
  if (huntCategoryFilter !== 'all') {
    filteredItems = huntItems.filter(item => item.category === huntCategoryFilter);
  }

  // Sort by name
  filteredItems.sort((a, b) => a.name.localeCompare(b.name));

  if (!filteredItems.length) {
    if (huntCategoryFilter === 'all') {
      container.innerHTML = `<div class="empty-state"><div class="empty-icon">🎯</div><div class="empty-text">No items on the hunt</div><div class="empty-sub">Tap + Add Item on the Hunt to start tracking items you're looking for</div></div>`;
    } else {
      container.innerHTML = `<div class="empty-state"><div class="empty-icon">🔍</div><div class="empty-text">No ${huntCategoryFilter} items</div><div class="empty-sub">Try selecting a different category</div></div>`;
    }
    return;
  }

  container.innerHTML = filteredItems.map(item => buildHuntItemCard(item)).join('');
}

function buildHuntItemCard(item) {
  const photosHtml = item.photos && item.photos.length > 0
    ? `<div style="width:100%;aspect-ratio:1/1;background:#f5f2ee;border-radius:12px 12px 0 0;overflow:hidden;margin-bottom:8px;">
         <img src="/.netlify/functions/images?id=${item.photos[0]}&size=thumb"
              alt="${esc(item.name)}"
              style="width:100%;height:100%;object-fit:cover;display:block;"
              loading="lazy"
              onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\\'width:100%;height:100%;background:#ede9e3;display:flex;align-items:center;justify-content:center;font-size:24px;color:#9a9080;\\'>🎯</div>';">
       </div>`
    : '';

  return `<div class="inv-card" onclick="openHuntDetail('${item.id}')" style="position:relative;">
    ${photosHtml}
    <div class="inv-card-header">
      <div><div class="inv-name">${esc(item.name)}</div><span class="category-chip">${esc(item.category || 'Other')}</span></div>
    </div>
    ${item.notes ? `<div class="inv-notes">${esc(item.notes)}</div>` : ''}
  </div>`;
}

function openHuntDetail(itemId) {
  const item = huntItems.find(i => i.id === itemId);
  if (!item) return;

  // Populate detail modal
  document.getElementById('hunt-detail-name').textContent = item.name;
  document.getElementById('hunt-detail-category').textContent = item.category || 'Other';
  document.getElementById('hunt-detail-created').textContent = new Date(item.created).toLocaleDateString();
  document.getElementById('hunt-detail-updated').textContent = new Date(item.updated).toLocaleDateString();

  // Handle photos
  const imageContainer = document.getElementById('hunt-detail-image-container');
  if (item.photos && item.photos.length > 0) {
    imageContainer.innerHTML = `<img src="/.netlify/functions/images?id=${item.photos[0]}" alt="${esc(item.name)}" style="width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:12px;" onclick="openImageModal('/.netlify/functions/images?id=${item.photos[0]}', '${esc(item.name)}')" loading="lazy">`;
  } else {
    imageContainer.innerHTML = '<div style="width:100%;aspect-ratio:1/1;background:#ede9e3;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:48px;color:#9a9080;">🎯</div>';
  }

  // Handle notes
  const notesWrap = document.getElementById('hunt-detail-notes-wrap');
  const notesDisplay = document.getElementById('hunt-detail-notes-display');
  if (item.notes && item.notes.trim()) {
    notesDisplay.textContent = item.notes;
    notesWrap.style.display = 'block';
  } else {
    notesWrap.style.display = 'none';
  }

  // Store current item ID for edit function
  window.currentHuntDetailId = itemId;

  // Show modal
  document.getElementById('modal-hunt-detail').classList.add('open');
}

function openAddHuntModal() {
  // Reset form
  document.getElementById('hunt-add-name').value = '';
  document.getElementById('hunt-add-category').value = 'Other';
  document.getElementById('hunt-add-notes').value = '';
  document.getElementById('hunt-add-image').value = '';

  // Reset image preview
  document.getElementById('hunt-add-image-preview').innerHTML = '🎯';
  document.getElementById('hunt-add-image-status').style.display = 'none';

  // Hide notes counter
  document.getElementById('hunt-add-notes-counter').style.display = 'none';

  // Show modal
  document.getElementById('modal-hunt-add').classList.add('open');
  document.getElementById('hunt-add-name').focus();
}

function openEditHuntModal(itemId) {
  const item = huntItems.find(i => i.id === itemId);
  if (!item) return;

  // Populate form
  document.getElementById('hunt-edit-id').value = item.id;
  document.getElementById('hunt-edit-name').value = item.name;
  document.getElementById('hunt-edit-category').value = item.category || 'Other';
  document.getElementById('hunt-edit-notes').value = item.notes || '';
  document.getElementById('hunt-edit-image').value = '';

  // Handle image preview
  const preview = document.getElementById('hunt-edit-image-preview');
  if (item.photos && item.photos.length > 0) {
    preview.innerHTML = `<img src="/.netlify/functions/images?id=${item.photos[0]}&size=thumb" alt="${esc(item.name)}" style="width:100%;height:100%;object-fit:cover;border-radius:8px;" loading="lazy">`;
  } else {
    preview.innerHTML = '🎯';
  }
  document.getElementById('hunt-edit-image-status').style.display = 'none';

  // Show/hide notes counter
  const notesCounter = document.getElementById('hunt-edit-notes-counter');
  if (item.notes && item.notes.trim()) {
    notesCounter.style.display = 'block';
    notesCounter.textContent = `${item.notes.length}/2000`;
  } else {
    notesCounter.style.display = 'none';
  }

  // Show delete button
  document.getElementById('btn-delete-hunt-item').style.display = 'block';

  // Show modal
  document.getElementById('modal-hunt-edit').classList.add('open');
  document.getElementById('hunt-edit-name').focus();
}

function editCurrentHuntItem() {
  if (window.currentHuntDetailId) {
    closeModal('modal-hunt-detail');
    openEditHuntModal(window.currentHuntDetailId);
  }
}

async function saveHuntItem() {
  const isEdit = document.getElementById('hunt-edit-id').value;
  const modalId = isEdit ? 'modal-hunt-edit' : 'modal-hunt-add';

  // Get form values
  const name = (isEdit ? document.getElementById('hunt-edit-name') : document.getElementById('hunt-add-name')).value.trim();
  const category = (isEdit ? document.getElementById('hunt-edit-category') : document.getElementById('hunt-add-category')).value;
  const notes = (isEdit ? document.getElementById('hunt-edit-notes') : document.getElementById('hunt-add-notes')).value.trim();

  // Validate required fields
  if (!name) {
    showToast('Please enter an item name');
    (isEdit ? document.getElementById('hunt-edit-name') : document.getElementById('hunt-add-name')).focus();
    return;
  }

  // Create item object
  const item = {
    name,
    category,
    notes: notes || undefined,
    updated: new Date().toISOString()
  };

  if (isEdit) {
    // Update existing item
    const existingItem = huntItems.find(i => i.id === document.getElementById('hunt-edit-id').value);
    if (!existingItem) {
      showToast('Item not found');
      return;
    }
    item.id = existingItem.id;
    item.photos = existingItem.photos || [];
    item.created = existingItem.created;
  } else {
    // New item
    item.id = Date.now().toString();
    item.photos = [];
    item.created = new Date().toISOString();
  }

  // Handle image upload if present
  const imageInput = document.getElementById(isEdit ? 'hunt-edit-image' : 'hunt-add-image');
  if (imageInput.files && imageInput.files[0]) {
    try {
      const result = await handleImageUpload(imageInput);
      if (result && result.imageId) {
        item.photos = [result.imageId]; // Replace existing photos for simplicity
      }
    } catch (error) {
      console.error('Image upload failed:', error);
      showToast('Failed to upload image, but saving item without it');
    }
  }

  // Add/update item in array
  if (isEdit) {
    const index = huntItems.findIndex(i => i.id === item.id);
    if (index !== -1) {
      huntItems[index] = item;
    }
  } else {
    huntItems.push(item);
  }

  // Save to server
  try {
    await saveHuntItems();
    showToast(isEdit ? 'Hunt item updated!' : 'Hunt item added!');
    closeModal(modalId);
    renderHunt();
  } catch (error) {
    console.error('Failed to save hunt item:', error);
    showToast('Failed to save hunt item');
  }
}

async function confirmDeleteHuntItem() {
  const itemId = document.getElementById('hunt-edit-id').value;
  const item = huntItems.find(i => i.id === itemId);
  if (!item) return;

  const ok = await showConfirm('Delete hunt item?', `"${item.name}" will be permanently removed.`);
  if (!ok) return;

  // Remove from array
  huntItems = huntItems.filter(i => i.id !== itemId);

  // Save to server
  try {
    await saveHuntItems();
    showToast('Hunt item deleted');
    closeModal('modal-hunt-edit');
    renderHunt();
  } catch (error) {
    console.error('Failed to delete hunt item:', error);
    showToast('Failed to delete hunt item');
  }
}

function handleHuntImageUpload(input) {
  return handleImageUpload(input);
}

function updateHuntNotesCounter(textareaId, counterId) {
  const textarea = document.getElementById(textareaId);
  const counter = document.getElementById(counterId);
  const length = textarea.value.length;

  if (length > 0) {
    counter.textContent = `${length}/2000`;
    counter.style.display = 'block';
  } else {
    counter.style.display = 'none';
  }

  // Change color if approaching limit
  if (length > 1800) {
    counter.style.color = 'var(--red)';
  } else if (length > 1500) {
    counter.style.color = 'var(--orange)';
  } else {
    counter.style.color = 'var(--text3)';
  }
}

// ── API helpers ──────────────────────────────────────────────
const getApiBaseUrl = () => {
  const hostname = window.location.hostname;

  // Local development
  if (hostname === 'localhost' || hostname === '127.0.0.1') {
    return '/.netlify/functions';
  }

  // Production - use relative path (Netlify handles routing)
  // Log for debugging production issues
  const apiPath = '/.netlify/functions';
  console.log('Using API base URL:', apiPath, 'for hostname:', hostname);
  return apiPath;
};

const API = getApiBaseUrl();

// Add timeout and retry logic for production reliability
const fetchWithTimeout = (url, options = {}, timeout = 15000) => {
  const controller = new AbortController();
  const timeoutId = setTimeout(() => controller.abort(), timeout);

  return fetch(url, {
    ...options,
    signal: controller.signal
  }).finally(() => {
    clearTimeout(timeoutId);
  });
};

// Retry logic for transient failures
const fetchWithRetry = async (url, options = {}, maxRetries = 2) => {
  let lastError;

  for (let attempt = 0; attempt <= maxRetries; attempt++) {
    try {
      const response = await fetchWithTimeout(url, options);
      return response;
    } catch (error) {
      lastError = error;
      console.warn(`API request attempt ${attempt + 1} failed:`, error.message);

      // Don't retry on client errors (4xx) or specific errors
      if (error.name === 'AbortError' || (error.message && error.message.includes('4'))) {
        throw error;
      }

      // If this was the last attempt, throw the error
      if (attempt === maxRetries) {
        throw lastError;
      }

      // Wait before retrying (exponential backoff)
      await new Promise(resolve => setTimeout(resolve, Math.pow(2, attempt) * 1000));
    }
  }
};

// ── Save Functions ──────────────────────────────────────────────
async function saveLocations() {
  try {
    const response = await fetch(`${API}/locations`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(locations)
    });
    if (!response.ok) {
      const error = await response.json().catch(() => ({ error: 'Unknown error' }));
      throw new Error(error.error || 'Failed to save locations');
    }
    return await response.json();
  } catch (error) {
    console.error('saveLocations error:', error);
    showToast('⚠ Failed to save locations');
    throw error;
  }
}

async function saveInventory() {
  try {
    const response = await fetch(`${API}/inventory`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(inventory)
    });
    if (!response.ok) {
      const error = await response.json().catch(() => ({ error: 'Unknown error' }));
      throw new Error(error.error || 'Failed to save inventory');
    }
    return await response.json();
  } catch (error) {
    console.error('saveInventory error:', error);
    showToast('⚠ Failed to save inventory');
    throw error;
  }
}

function cancelDetailNotesEdit() {
  // Reset the textarea to current notes value
  const item = inventory.find(i => i.id === currentDetailId);
  if (item) {
    document.getElementById('detail-notes-edit').value = item.notes || '';
    updateDetailNotesCounter();
  }
}

function saveDetailNotes() {
  const notes = document.getElementById('detail-notes-edit').value;
  fetch('/.netlify/functions/inventory?action=updateNotes', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ itemId: currentDetailId, notes })
  }).then(response => {
    if (response.ok) {
      return response.json();
    } else {
      throw new Error('Failed to save notes');
    }
  }).then(updatedItem => {
    const itemIndex = inventory.findIndex(i => i.id === currentDetailId);
    if (itemIndex !== -1) {
      inventory[itemIndex] = updatedItem;
    }
    renderList();
    showToast('Notes saved successfully');
    closeModal('modal-detail');
  }).catch(error => {
    console.error(error);
    showToast('Failed to save notes');
  });
}

function toggleWarehouseTransfer() {
  const checkbox = document.getElementById('f-transfer-from-warehouse');
  const warehouseSection = document.getElementById('warehouse-transfer-section');
  const warehouseInfo = document.getElementById('warehouse-info');

  if (checkbox.checked) {
    warehouseSection.style.display = 'block';
    updateWarehouseInfo();
  } else {
    warehouseSection.style.display = 'none';
    warehouseInfo.style.display = 'none';
  }
}

function onCategoryChange() {
  // Called when category selection changes in the add item modal
  // Could be used to show/hide category-specific options
  showWarehouseTransferSection();
}

function showWarehouseTransferSection() {
  const warehouse = locations.find(loc => loc.isWarehouse);
  const section = document.getElementById('warehouse-transfer-section');

  // Only manipulate the element if it exists (i.e., when the modal is open)
  if (section) {
    if (warehouse && locations.filter(loc => loc.active).length > 1) {
      section.style.display = 'block';
    } else {
      section.style.display = 'none';
    }
  }
}

async function performWarehouseTransfer(itemId, toLocation, quantity) {
  const warehouse = locations.find(loc => loc.isWarehouse);
  if (!warehouse) {
    throw new Error('No warehouse configured');
  }

  const response = await fetch(`${API}/inventory?action=transfer`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      itemId,
      fromLocation: warehouse.id,
      toLocation,
      quantity: parseInt(quantity)
    })
  });

  if (!response.ok) {
    const error = await response.json();
    throw new Error(error.error || 'Transfer failed');
  }

  const result = await response.json();
  return result;
}

// ── Location Setup Validation ────────────────────────────────────
function showLocationSetupMessage() {
  showConfirm(
    'No Locations Configured',
    'Please configure at least one location in Settings before adding inventory.',
    'Go to Settings'
  ).then(confirmed => {
    if (confirmed) {
      switchTab('settings');
    }
  });
}

function populateLocationSelect() {
  const select = document.getElementById('f-location');
  if (!select) return;

  // Clear existing options
  select.innerHTML = '';

  // Add active locations
  const activeLocations = locations.filter(loc => loc.active);
  activeLocations.forEach(loc => {
    const option = document.createElement('option');
    option.value = loc.id;
    option.textContent = loc.name;
    select.appendChild(option);
  });

  // If no locations, add a disabled placeholder
  if (activeLocations.length === 0) {
    const option = document.createElement('option');
    option.value = '';
    option.textContent = 'No locations configured';
    option.disabled = true;
    select.appendChild(option);
  }
}

function populateExpenseLocationSelect() {
  const select = document.getElementById('e-location');
  if (!select) return;

  // Clear existing options
  select.innerHTML = '';

  // Add active locations
  const activeLocations = locations.filter(loc => loc.active);
  activeLocations.forEach(loc => {
    const option = document.createElement('option');
    option.value = loc.id;
    option.textContent = loc.name;
    select.appendChild(option);
  });

  // If no locations, add a disabled placeholder
  if (activeLocations.length === 0) {
    const option = document.createElement('option');
    option.value = '';
    option.textContent = 'No locations configured';
    option.disabled = true;
    select.appendChild(option);
  }
}

function performArchive(id) {
  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  loc.archived = true;
  loc.archivedDate = new Date().toISOString();
  loc.archivedReason = 'Location archived to preserve transaction history';

  saveLocations();
  renderLocationSettings();
  renderList();
  populateInventoryLocationFilter();
  populatePnLLocationFilter();
  showToast('✓ Location archived - transaction history preserved');
}

function unarchiveLocation(id) {
  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  loc.archived = false;
  delete loc.archivedDate;
  delete loc.archivedReason;

  saveLocations();
  renderLocationSettings();
  renderList();
  populateInventoryLocationFilter();
  populatePnLLocationFilter();
  showToast('✓ Location restored');
}

function setWarehouse(id) {
  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  // If this location is already the warehouse, unset it
  if (loc.isWarehouse) {
    loc.isWarehouse = false;
    showToast('✓ Warehouse designation removed');
  } else {
    // Unset any existing warehouse
    locations.forEach(l => l.isWarehouse = false);
    // Set this location as warehouse
    loc.isWarehouse = true;
    showToast('✓ Warehouse set to ' + loc.name);
  }

  saveLocations();
  renderLocationSettings();
}

async function deleteLocation(id) {
  if (locations.length <= 1) {
    showToast('Cannot delete the last location');
    return;
  }

  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  // Check if location has inventory
  const hasInventory = inventory.some(item =>
    item.inventory && item.inventory[id] && item.inventory[id].qty > 0
  );

  // Count sales records for this location
  const salesCount = inventory.reduce((total, item) => {
    return total + (item.sales || []).filter(sale => sale.location === id).length;
  }, 0);

  // Count expense records for this location
  const expenseCount = expenses.filter(exp => exp.location === id).length;

  // Build warning message
  let warningMsg = 'This will permanently delete the location and all associated data. ';
  const issues = [];

  if (hasInventory) {
    issues.push('This location has current inventory that will be orphaned');
  }

  if (salesCount > 0) {
    issues.push(`${salesCount} sales record${salesCount !== 1 ? 's' : ''} will be orphaned`);
  }

  if (expenseCount > 0) {
    issues.push(`${expenseCount} expense record${expenseCount !== 1 ? 's' : ''} will be orphaned`);
  }

  if (issues.length > 0) {
    warningMsg += 'WARNING: ' + issues.join(', ') + '. This will cause accounting reconciliation issues and break transaction history. ';
  }

  warningMsg += 'This action is primarily intended for testing cleanup and cannot be undone.';

  const ok = await showConfirm(
    'Delete Location?',
    warningMsg,
    'Delete Anyway'
  );

  if (!ok) return;

  locations = locations.filter(l => l.id !== id);
  saveLocations();
  renderLocationSettings();
  renderList();
  populateInventoryLocationFilter(); // Update inventory filter
  populatePnLLocationFilter(); // Update P&L filter
  showToast('✓ Location deleted - data may be orphaned');
}

function openEditLocationModal(id) {
  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  document.getElementById('location-edit-id').value = id;
  document.getElementById('location-name').value = loc.name;
  document.getElementById('location-type').value = loc.type;
  document.getElementById('location-rent').value = loc.monthlyRent || '';
  document.getElementById('location-fee').value = loc.transactionFeePercent || '';
  document.getElementById('location-active').checked = loc.active;
  document.getElementById('location-warehouse').checked = loc.isWarehouse;

  document.getElementById('modal-location-edit').classList.add('open');
}

function saveLocationEdit() {
  const id = document.getElementById('location-edit-id').value;
  const loc = locations.find(l => l.id === id);
  if (!loc) return;

  const newName = document.getElementById('location-name').value.trim();
  if (!newName) {
    document.getElementById('location-name').focus();
    return;
  }

  // Check if name is already taken by another location
  const existingLoc = locations.find(l => l.id !== id && l.name.toLowerCase() === newName.toLowerCase());
  if (existingLoc) {
    showToast('Location name already exists');
    document.getElementById('location-name').focus();
    return;
  }

  const newType = document.getElementById('location-type').value;
  const newActive = document.getElementById('location-active').checked;
  const newWarehouse = document.getElementById('location-warehouse').checked;
  const newMonthlyRent = parseFloat(document.getElementById('location-rent').value) || 0;
  const newTransactionFeePercent = parseFloat(document.getElementById('location-fee').value) || 0;

  // Validate transaction fee percentage
  if (newTransactionFeePercent < 0 || newTransactionFeePercent > 100) {
    showToast('Transaction fee must be between 0% and 100%');
    document.getElementById('location-fee').focus();
    return;
  }

  // If setting as warehouse, unset any existing warehouse
  if (newWarehouse && !loc.isWarehouse) {
    locations.forEach(l => l.isWarehouse = false);
  }

  // Update location properties
  loc.name = newName;
  loc.type = newType;
  loc.active = newActive;
  loc.isWarehouse = newWarehouse;
  loc.monthlyRent = newMonthlyRent;
  loc.transactionFeePercent = newTransactionFeePercent;

  saveLocations();
  closeModal('modal-location-edit');
  renderLocationSettings();
  renderList();
  populateInventoryLocationFilter();
  populatePnLLocationFilter();
  showToast('✓ Location updated');
}

function renderLocationSettings() {
  const container = document.getElementById('location-settings-list');
  if (!container) return;

  // Separate active and archived locations
  const activeLocations = locations.filter(loc => !loc.archived);
  const archivedLocations = locations.filter(loc => loc.archived);

  let html = '';

  // Active locations section
  if (activeLocations.length > 0) {
    html += activeLocations.map(loc => `
      <div class="inv-card" style="cursor:default;">
        <div class="inv-card-header">
          <div>
            <div class="inv-name">${esc(loc.name)}</div>
            <span class="category-chip">${loc.type === 'storage' ? 'Storage' : 'Retail Booth'}${loc.isWarehouse ? ' · 🏭 Warehouse' : ''}</span>
          </div>
          <div style="display:flex;gap:8px;">
            <button onclick="openEditLocationModal('${loc.id}')"
                    style="background:var(--accent);color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;">
              Edit
            </button>
            ${loc.active ? `<button onclick="setWarehouse('${loc.id}')"
                    style="background:${loc.isWarehouse ? 'var(--accent3)' : 'var(--text3)'};color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;">
              ${loc.isWarehouse ? 'Warehouse' : 'Set as Warehouse'}
            </button>` : ''}
            <button onclick="toggleLocationActive('${loc.id}')"
                    style="background:${loc.active ? 'var(--accent2)' : 'var(--text3)'};color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;">
              ${loc.active ? 'Active' : 'Inactive'}
            </button>
            <button onclick="archiveLocation('${loc.id}')"
                    style="background:var(--accent3);color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;">
              Archive
            </button>
          </div>
        </div>
      </div>
    `).join('');
  }

  // Archived locations section
  if (archivedLocations.length > 0) {
    html += `
      <div style="margin:20px 0 12px 0;padding:12px 16px;background:var(--surface2);border-radius:var(--radius-sm);border:1px solid var(--border);">
        <div style="font-size:11px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);margin-bottom:4px;">Archived Locations</div>
        <div style="font-size:12px;color:var(--text3);line-height:1.4;">These locations are no longer active but their transaction history is preserved.</div>
      </div>
    `;

    html += archivedLocations.map(loc => `
      <div class="inv-card" style="cursor:default;opacity:.75;border-color:var(--text3);">
        <div class="inv-card-header">
          <div>
            <div class="inv-name">${esc(loc.name)} <span style="font-size:11px;color:var(--text3);font-weight:400;">(Archived)</span></div>
            <span class="category-chip">${loc.type === 'storage' ? 'Storage' : 'Retail Booth'}</span>
            ${loc.archivedDate ? `<div style="font-size:10px;color:var(--text3);margin-top:2px;">Archived: ${new Date(loc.archivedDate).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}</div>` : ''}
          </div>
          <div style="display:flex;gap:8px;">
            <button onclick="unarchiveLocation('${loc.id}')"
                    style="background:var(--accent2);color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;">
              Unarchive
            </button>
            <button onclick="deleteLocation('${loc.id}')"
                    style="background:var(--danger);color:#fff;border:none;border-radius:6px;padding:6px 12px;font-size:12px;font-weight:600;">
              Delete
            </button>
          </div>
        </div>
      </div>
    `).join('');
  }

  container.innerHTML = html;
}

// ── Tabs ───────────────────────────────────────────────────
function switchTab(n) {
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+n).classList.add('active');
  document.getElementById('nav-'+n).classList.add('active');
  if(n==='inventory') populateInventoryLocationFilter();
  if(n==='pnl')      { renderPnL(); renderIncomeStatement(); }
  if(n==='loans')    renderLoans();
  if(n==='expenses') renderExpenses();
  if(n==='reports')  renderReports();
  if(n==='settings') renderLocationSettings();
}

// ── Render Inventory ───────────────────────────────────────
let soldSectionOpen = true;

// Helper function to calculate total quantity across all locations
function calculateTotalQty(item) {
  if (!item.inventory) return 0;
  return Object.values(item.inventory).reduce((sum, loc) => sum + Number(loc.qty || 0), 0);
}

function renderList() {
  const q = (document.getElementById('search-box').value||'').toLowerCase();
  const allMatch = inventory.filter(i=>i.name.toLowerCase().includes(q)||i.category.toLowerCase().includes(q)||(i.notes?.toLowerCase().includes(q)));

  // Calculate totals across all locations for each item (consistent with server)
  allMatch.forEach(item => {
    item.totalQty = calculateTotalQty(item);
  });

  // Filter items by selected location
  let filteredItems = allMatch;
  if (inventoryLocationFilter !== 'all') {
    filteredItems = allMatch.filter(item => {
      if (!item.inventory) return false;
      return item.inventory[inventoryLocationFilter] && Number(item.inventory[inventoryLocationFilter].qty) > 0;
    });
  }

  // Split: in-stock = totalQty > 0, sold-out = totalQty === 0 AND has sales history
  const inStock = filteredItems.filter(i => Number(i.totalQty) > 0).sort((a,b)=>a.name.localeCompare(b.name));
  const soldOut = filteredItems.filter(i => Number(i.totalQty) === 0 && (i.sales||[]).length > 0).sort((a,b)=>a.name.localeCompare(b.name));



  // In-stock list
  const el = document.getElementById('inv-list');
  if (!inStock.length && !q) {
    if (inventoryLocationFilter === 'all' && locations.filter(loc => loc.active).length === 0) {
      el.innerHTML=`<div class="empty-state"><div class="empty-icon">📍</div><div class="empty-text">No locations configured</div><div class="empty-sub">Go to Settings to add your first location</div></div>`;
    } else {
      el.innerHTML=`<div class="empty-state"><div class="empty-icon">📭</div><div class="empty-text">No items in stock</div><div class="empty-sub">Tap + Add Item to get started</div></div>`;
    }
  } else if (!inStock.length && q) {
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">🔍</div><div class="empty-text">No matches</div><div class="empty-sub">Try a different search</div></div>`;
  } else {
    el.innerHTML = inStock.map(item => buildItemCard(item)).join('');
  }

  // Sold section
  renderSoldList(soldOut);
}

function getItemPrimaryLocation(item) {
  if (!item.inventory) return null;

  // Find locations with inventory for this item
  const locationsWithInventory = Object.keys(item.inventory)
    .filter(locId => Number(item.inventory[locId]?.qty) > 0)
    .map(locId => ({ id: locId, qty: Number(item.inventory[locId]?.qty) }));

  if (locationsWithInventory.length === 0) return null;

  // Return location with highest quantity, or first if tie
  return locationsWithInventory.sort((a, b) => b.qty - a.qty)[0].id;
}

function calculateAdjustedMargin(item) {
  const primaryLocationId = getItemPrimaryLocation(item);
  const location = locations.find(l => l.id === primaryLocationId);
  const transactionFeePercent = location?.transactionFeePercent || 0;

  const suggested = Number(item.suggestedPrice ?? item.salePrice ?? 0);
  const effectiveRevenue = suggested * (1 - transactionFeePercent / 100);
  const cost = Number(item.cost) + Number(item.labor);
  const netProfit = effectiveRevenue - cost;

  return suggested > 0 ? Math.round((netProfit / suggested) * 100) : 0;
}

function buildItemCard(item) {
  const suggested = Number(item.suggestedPrice ?? item.salePrice ?? 0);
  const primaryLocationId = getItemPrimaryLocation(item);
  const location = locations.find(l => l.id === primaryLocationId);
  const transactionFeePercent = location?.transactionFeePercent || 0;

  // Calculate adjusted margin after transaction fee
  const adjustedMargin = calculateAdjustedMargin(item);
  const thresh = Number(item.reorderPt ?? 5);

  // Calculate total quantity across all locations
  const totalQty = item.totalQty || 0;

  // Show location breakdown for mobile
  const locationBreakdown = locations
    .filter(loc => loc.active)
    .map(loc => {
      const qty = Number((item.inventory?.[loc.id]?.qty) || 0);
      return qty > 0 ? `${loc.name}: ${qty}` : null;
    })
    .filter(Boolean)
    .join(' · ');

  // Check for pending image upload in edit modal (for immediate preview)
  const editId = document.getElementById('edit-id')?.value;
  const pendingImageUrl = (editId === item.id) ? document.getElementById('f-image')?.dataset?.imageUrl : null;
  const displayImageUrl = pendingImageUrl || (item.imageId ? `/.netlify/functions/images?id=${item.imageId}` : null);

  let imageHtml = '';
  if (displayImageUrl) {
    // Use thumbnail for card display
    const thumbUrl = displayImageUrl + '&size=thumb';
    const imgContainer = document.createElement('div');
    imgContainer.style.cssText = 'width:100%;aspect-ratio:1/1;background:#f5f2ee;border-radius:12px 12px 0 0;overflow:hidden;margin-bottom:8px;cursor:pointer;';
    imgContainer.onclick = (e) => {
      e.stopPropagation(); // Prevent card click
      openImageModal(displayImageUrl, item.name);
    };

    const img = document.createElement('img');
    img.src = thumbUrl;
    img.alt = item.name;
    img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
    img.loading = 'lazy';
    img.onload = () => console.log('✅ Thumbnail loaded successfully for ' + item.name);
    img.onerror = async () => {
      console.warn('❌ Server thumbnail failed for ' + item.name + ', trying client-side generation');

      try {
        // Try client-side thumbnail generation as fallback
        const thumbnailBlob = await generateClientThumbnail(displayImageUrl);
        const thumbnailUrl = URL.createObjectURL(thumbnailBlob);

        // Replace the failed image with the client-generated thumbnail
        img.src = thumbnailUrl;
        img.onload = () => {
          console.log('✅ Client-side thumbnail generated for ' + item.name);
          // Clean up the object URL after image loads
          URL.revokeObjectURL(thumbnailUrl);
        };
        img.onerror = () => {
          console.error('❌ Client-side thumbnail also failed for ' + item.name);
          URL.revokeObjectURL(thumbnailUrl);
          img.style.display = 'none';
          imgContainer.innerHTML = '<div style="width:100%;height:100%;background:#ede9e3;display:flex;align-items:center;justify-content:center;font-size:24px;color:#9a9080;">📦</div>';
        };
      } catch (clientError) {
        console.error('❌ Client-side thumbnail generation failed for ' + item.name + ':', clientError);
        img.style.display = 'none';
        imgContainer.innerHTML = '<div style="width:100%;height:100%;background:#ede9e3;display:flex;align-items:center;justify-content:center;font-size:24px;color:#9a9080;">📦</div>';
      }
    };

    imgContainer.appendChild(img);
    imageHtml = imgContainer.outerHTML;
  }

  return `<div class="inv-card" onclick="openDetail('${item.id}')" style="position:relative;">
    ${imageHtml}
    <div class="inv-card-header">
      <div><div class="inv-name">${esc(item.name)}</div><span class="category-chip">${esc(item.category)}</span></div>
      <div class="inv-qty-badge ${totalQty<=thresh?'low':'ok'}">${totalQty} ${esc(item.unit||'units')}</div>
    </div>
    ${locationBreakdown ? `<div style="font-size:11px;color:var(--text3);padding:0 14px 8px;margin-top:-4px;">${esc(locationBreakdown)}</div>` : ''}
    <div class="margin-bar"><div class="margin-fill" style="width:${Math.min(100,Math.max(0,adjustedMargin))}%"></div></div>
    <div class="inv-metrics">
      <div class="inv-metric"><div class="inv-metric-label">Cost</div><div class="inv-metric-value cost">${fmt(item.cost)}</div></div>
      <div class="inv-metric"><div class="inv-metric-label">Labor</div><div class="inv-metric-value cost">${fmt(item.labor)}</div></div>
      <div class="inv-metric"><div class="inv-metric-label">Fee</div><div class="inv-metric-value">${transactionFeePercent}%</div></div>
      <div class="inv-metric"><div class="inv-metric-label">Sug.</div><div class="inv-metric-value highlight">${fmt(suggested)}</div></div>
      <div class="inv-metric"><div class="inv-metric-label">Margin</div><div class="inv-metric-value price">${adjustedMargin}%</div></div>
    </div>${item.notes && item.notes.trim() ? `<div class="inv-notes">${esc(item.notes)}</div>` : ''}</div>`;
}

function renderSoldList(soldItems) {
  const sec = document.getElementById('sold-section');
  const list = document.getElementById('sold-list');
  const badge = document.getElementById('sold-count-badge');
  const arrow = document.getElementById('sold-toggle-arrow');

  // Create location-specific sale entries for ALL items with sales history
  let locationSpecificSales = [];

  inventory.forEach(item => {
    if (!item.sales || item.sales.length === 0) return;

    // Calculate total quantity across all locations for this item
    const totalQtyAcrossAllLocations = item.inventory ?
      Object.values(item.inventory).reduce((sum, loc) => sum + Number(loc.qty || 0), 0) : 0;

    // Group sales by location for this item
    const salesByLocation = {};
    item.sales.forEach(sale => {
      const locationId = sale.location || 'unknown';
      if (!salesByLocation[locationId]) {
        salesByLocation[locationId] = [];
      }
      salesByLocation[locationId].push(sale);
    });

    // Create an entry for each location
    Object.keys(salesByLocation).forEach(locationId => {
      const locationSales = salesByLocation[locationId];
      const totalSoldQty = locationSales.reduce((s, sl) => s + Number(sl.qty), 0);
      const totalRevenue = locationSales.reduce((s, sl) => s + Number(sl.revenue), 0);
      const totalTransactionFee = locationSales.reduce((s, sl) => s + Number(sl.transactionFee || 0), 0);

      // Get transaction fee percentage for this location
      const location = locations.find(l => l.id === locationId);
      const transactionFeePercent = location?.transactionFeePercent || 0;

      // Calculate net revenue after transaction fee
      const netRevenue = totalRevenue - totalTransactionFee;

      // Calculate net profit: net revenue - cost - labor
      const totalCostBasis = locationSales.reduce((s, sl) => s + (Number(item.cost) + Number(item.labor)) * Number(sl.qty), 0);
      const netProfit = netRevenue - totalCostBasis;

      // Calculate margin %: (Net Profit / Effective Revenue) × 100
      // Effective revenue = suggested price after transaction fee
      const suggestedPrice = Number(item.suggestedPrice ?? item.salePrice ?? 0);
      const effectiveRevenue = suggestedPrice * (1 - (transactionFeePercent / 100));
      const marginPercent = effectiveRevenue > 0 ? Math.round((netProfit / effectiveRevenue) * 100) : 0;

      // Filter by location if needed
      if (inventoryLocationFilter !== 'all' && locationId !== inventoryLocationFilter) {
        return;
      }

      locationSpecificSales.push({
        item: item,
        locationId: locationId,
        locationName: locations.find(l => l.id === locationId)?.name || 'Unknown Location',
        sales: locationSales,
        totalSoldQty: totalSoldQty,
        totalRevenue: totalRevenue,
        totalTransactionFee: totalTransactionFee,
        netRevenue: netRevenue,
        netProfit: netProfit,
        marginPercent: marginPercent,
        transactionFeePercent: transactionFeePercent,
        lastSale: locationSales.sort((a, b) => new Date(b.date) - new Date(a.date))[0]
      });
    });
  });

  // Sort by item name, then location name
  locationSpecificSales.sort((a, b) => {
    const itemCompare = a.item.name.localeCompare(b.item.name);
    if (itemCompare !== 0) return itemCompare;
    return a.locationName.localeCompare(b.locationName);
  });

  if (!locationSpecificSales.length) { sec.style.display='none'; return; }

  sec.style.display = 'block';
  badge.textContent = locationSpecificSales.length;
  arrow.style.transform = soldSectionOpen ? 'rotate(0deg)' : 'rotate(-90deg)';
  list.style.display = soldSectionOpen ? 'flex' : 'none';

  if (!soldSectionOpen) return;

  list.innerHTML = locationSpecificSales.map(entry => {
    const { item, locationName, totalSoldQty, totalRevenue, totalTransactionFee, netRevenue, netProfit, transactionFeePercent, marginPercent, lastSale } = entry;

    return `<div class="inv-card" onclick="openDetail('${item.id}')" style="opacity:1">
      <div class="inv-card-header">
        <div style="flex:1;padding-right:10px;">
          <div class="inv-name">${esc(item.name)}</div>
          <span class="category-chip">${esc(item.category)}</span>
          <div style="font-size:11px;color:var(--accent);font-weight:600;margin-top:4px;">📍 ${esc(locationName)}</div>
        </div>
        <div style="text-align:right;">
          <div style="font-size:12px;font-weight:700;font-family:var(--font-mono);margin-bottom:4px;${netProfit>=0?'color:var(--accent2);':'color:var(--danger);'}">
            ${netProfit>=0?'+':''}${fmt(netProfit)}
          </div>
          <div style="background:#f0faf6;border:1.5px solid var(--accent2);border-radius:9px;padding:4px 10px;font-family:var(--font-mono);font-size:12px;font-weight:600;color:var(--accent2);white-space:nowrap;">${totalSoldQty} sold</div>
          <div style="font-size:10px;color:var(--text3);font-family:var(--font-mono);margin-top:4px;">${lastSale?new Date(lastSale.date).toLocaleDateString('en-US',{month:'short',day:'numeric'}):'—'}</div>
        </div>
      </div>
      <div class="inv-metrics">
        <div class="inv-metric"><div class="inv-metric-label">Suggested</div><div class="inv-metric-value highlight">${fmt(item.suggestedPrice ?? item.salePrice ?? 0)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Revenue</div><div class="inv-metric-value highlight">${fmt(totalRevenue)}</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Fee</div><div class="inv-metric-value">${transactionFeePercent}%</div></div>
        <div class="inv-metric"><div class="inv-metric-label">Margin</div><div class="inv-metric-value price">${marginPercent}%</div></div>
      </div></div>`;
  }).join('');
}

function toggleSoldSection() {
  soldSectionOpen = !soldSectionOpen;
  const allWithSales = inventory.filter(i=>(i.sales||[]).length>0).sort((a,b)=>a.name.localeCompare(b.name));
  renderSoldList(allWithSales);
}

// ── Add/Edit Item ──────────────────────────────────────────
function updateCalc() {
  const c=parseFloat(document.getElementById('f-cost').value)||0;
  const l=parseFloat(document.getElementById('f-labor').value)||0;
  const s=parseFloat(document.getElementById('f-suggested-price').value)||0;
  const tc=c+l, p=s-tc, m=s>0?Math.round((p/s)*100):0;
  document.getElementById('calc-total-cost').textContent=fmt(tc);
  const pe=document.getElementById('calc-profit'), me=document.getElementById('calc-margin');
  pe.textContent=fmt(p); pe.className='calc-item-val '+(p>=0?'pos':'neg');
  me.textContent=m+'%'; me.className='calc-item-val '+(m>=0?'pos':'neg');
}

async function handleImageUpload(input) {
  const file = input.files[0];
  if (!file) return;

  const preview = document.getElementById('image-preview');
  const status = document.getElementById('image-status');

  // Show loading state
  preview.innerHTML = '⏳';
  status.textContent = 'Uploading...';
  status.style.display = 'block';

  try {
    const formData = new FormData();
    formData.append('image', file);

    const response = await fetch(`${API}/images`, {
      method: 'POST',
      body: formData
    });

    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.error || 'Upload failed');
    }

    const result = await response.json();

    // Store the image ID for later use in saveItem
    input.dataset.imageId = result.imageId;
    input.dataset.imageUrl = result.url;

    // Show preview with improved retry logic and better error handling
    const showPreviewWithRetry = async (url, maxRetries = 5) => {
      for (let attempt = 1; attempt <= maxRetries; attempt++) {
        try {
          console.log(`Preview attempt ${attempt}/${maxRetries} for: ${url}`);

          // Create a promise that resolves when image loads or fails
          const loadPromise = new Promise((resolve, reject) => {
            const imgElement = document.createElement('img');
            // Use cache busting but ensure proper URL construction
            const separator = url.includes('?') ? '&' : '?';
            imgElement.src = `${url}${separator}t=${Date.now()}`;
            imgElement.alt = 'Preview';
            imgElement.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:6px;';

            let hasResolved = false;

            imgElement.onload = () => {
              if (hasResolved) return;
              hasResolved = true;
              console.log(`✅ Preview image loaded successfully on attempt ${attempt}`);
              preview.innerHTML = '';
              preview.appendChild(imgElement);
              resolve();
            };

            imgElement.onerror = (event) => {
              if (hasResolved) return;
              hasResolved = true;
              console.warn(`❌ Preview image failed to load on attempt ${attempt}:`, {
                url: imgElement.src,
                error: event,
                status: imgElement.complete ? 'Image failed to load' : 'Network error'
              });
              reject(new Error(`Attempt ${attempt} failed: ${event.type}`));
            };

            // Add timeout for this attempt (increasing timeout for later attempts)
            const timeoutMs = 2000 + (attempt * 500); // 2s, 2.5s, 3s, 3.5s, 4s
            setTimeout(() => {
              if (!hasResolved) {
                hasResolved = true;
                console.warn(`⏰ Preview image timed out on attempt ${attempt} after ${timeoutMs}ms:`, url);
                reject(new Error(`Attempt ${attempt} timed out after ${timeoutMs}ms`));
              }
            }, timeoutMs);
          });

          await loadPromise;
          return; // Success, exit the retry loop

        } catch (error) {
          console.warn(`⚠️ Preview attempt ${attempt} failed:`, error.message);

          if (attempt === maxRetries) {
            // All attempts failed - show failure state but don't throw
            console.error('❌ All preview attempts failed after', maxRetries, 'retries:', error);
            preview.innerHTML = '📦';
            status.textContent = '❌ Preview failed to load after all retries';
            status.style.color = 'var(--danger)';
            return;
          }

          // Wait before next attempt with exponential backoff
          const delay = Math.min(500 * Math.pow(1.5, attempt - 1), 3000); // 500ms, 750ms, 1125ms, 1688ms, 2531ms
          console.log(`⏳ Waiting ${delay}ms before retry ${attempt + 1}/${maxRetries}...`);
          await new Promise(resolve => setTimeout(resolve, delay));
        }
      }
    };

    // Delay to allow blob storage to commit, then try to show preview
    setTimeout(async () => {
      try {
        await showPreviewWithRetry(result.url);
        status.textContent = '✓ Image uploaded and preview loaded';
        status.style.color = 'var(--accent2)';
      } catch (error) {
        console.error('Preview loading failed after all retries:', error);
        status.textContent = '❌ Preview failed to load';
        status.style.color = 'var(--danger)';
      }
    }, 2000); // Increased delay for blob storage commit
    status.textContent = '✓ Image uploaded successfully';
    status.style.color = 'var(--accent2)';

   } catch (error) {
     console.error('Image upload error:', error);
     preview.innerHTML = '📦';
     status.textContent = `❌ Upload failed: ${error.message}`;
     status.style.color = 'var(--danger)';
     // Clear the file input and any stored image data
     input.value = '';
     delete input.dataset.imageUrl;
     delete input.dataset.imageId;
   }
}

function openAddModal() {
  // Check if any active locations exist
  const activeLocations = locations.filter(loc => loc.active);
  if (activeLocations.length === 0) {
    showLocationSetupMessage();
    return;
  }

  ['edit-id','f-name','f-qty','f-cost','f-labor','f-suggested-price','f-notes'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('f-reorder').value='5';
  document.getElementById('f-category').value='Art';
  populateUnitSelect('print');
  populateLocationSelect();

  // Pre-select the current location filter if it's not "all"
  if (inventoryLocationFilter !== 'all') {
    document.getElementById('f-location').value = inventoryLocationFilter;
  }

  // Reset warehouse transfer checkbox
  document.getElementById('f-transfer-from-warehouse').checked = false;
  toggleWarehouseTransfer();

  // Reset image upload
  const _imgReset = document.getElementById('f-image');
  _imgReset.value = '';
  delete _imgReset.dataset.imageUrl;
  delete _imgReset.dataset.imageId;
  document.getElementById('image-preview').innerHTML = '📦';
  document.getElementById('image-status').style.display = 'none';

  // Add event listener for item name to update warehouse info
  const nameInput = document.getElementById('f-name');
  nameInput.addEventListener('input', updateWarehouseInfo);

  document.getElementById('modal-title').textContent='Add Item';
  document.getElementById('btn-delete-item').style.display='none';
  updateCalc();
  document.getElementById('modal-add').classList.add('open');
}

function openEditModal(id) {
  const item=inventory.find(i=>i.id===id); if(!item) return;
  document.getElementById('modal-title').textContent='Edit Item';
  document.getElementById('edit-id').value=id;
  document.getElementById('f-name').value=item.name;
  document.getElementById('f-category').value=item.category;

  // Populate location select first so we can pre-select the item's primary location
  populateLocationSelect();
  const primaryLocId = getItemPrimaryLocation(item);
  if (primaryLocId) {
    document.getElementById('f-location').value = primaryLocId;
  }

  // Qty: migrated items store quantities in item.inventory per-location, not item.qty
  const editLocId = document.getElementById('f-location').value;
  const editLocQty = (item.inventory && editLocId && item.inventory[editLocId])
    ? (item.inventory[editLocId].qty ?? 0)
    : (typeof item.qty !== 'undefined' ? item.qty : 0);
  document.getElementById('f-qty').value = editLocQty;

  document.getElementById('f-reorder').value=item.reorderPt??5;
  document.getElementById('f-cost').value=item.cost;
  document.getElementById('f-labor').value=item.labor;
  document.getElementById('f-suggested-price').value=item.suggestedPrice ?? item.salePrice ?? ''; // backward compat
  document.getElementById('f-notes').value=item.notes||'';
  populateUnitSelect(item.unit);

  // Handle existing image
  const imageInput = document.getElementById('f-image');
  const imagePreview = document.getElementById('image-preview');
  const imageStatus = document.getElementById('image-status');

  if (item.imageId) {
    const imageUrl = `/.netlify/functions/images?id=${item.imageId}`;
    imageInput.dataset.imageId = item.imageId;
    imageInput.dataset.imageUrl = imageUrl;
    imagePreview.innerHTML = `<img src="${esc(imageUrl)}" alt="Current image" style="width:100%;height:100%;object-fit:cover;border-radius:6px;"><button type="button" onclick="removeImage()" style="position:absolute;top:4px;right:4px;background:var(--danger);color:#fff;border:none;border-radius:50%;width:24px;height:24px;font-size:12px;display:flex;align-items:center;justify-content:center;">×</button>`;
    imagePreview.style.position = 'relative';
    imageStatus.textContent = 'Current image loaded';
    imageStatus.style.color = 'var(--accent2)';
    imageStatus.style.display = 'block';
  } else {
    imageInput.value = '';
    delete imageInput.dataset.imageId;
    delete imageInput.dataset.imageUrl;
    imagePreview.innerHTML = '📦';
    imagePreview.style.position = '';
    imageStatus.style.display = 'none';
  }
}

async function saveItem() {
  // Get form values
  const isEdit = document.getElementById('edit-id').value;
  const name = document.getElementById('f-name').value.trim();
  const category = document.getElementById('f-category').value;
  const location = document.getElementById('f-location').value;
  const qty = parseInt(document.getElementById('f-qty').value) || 0;
  const reorderPt = parseInt(document.getElementById('f-reorder').value) || 5;
  const cost = parseFloat(document.getElementById('f-cost').value) || 0;
  const labor = parseFloat(document.getElementById('f-labor').value) || 0;
  const suggestedPrice = parseFloat(document.getElementById('f-suggested-price').value) || 0;
  const notes = document.getElementById('f-notes').value.trim();
  const transferFromWarehouse = document.getElementById('f-transfer-from-warehouse').checked;

  // Validate required fields
  if (!name) {
    showToast('Please enter an item name');
    document.getElementById('f-name').focus();
    return;
  }

  if (!location) {
    showToast('Please select a location');
    document.getElementById('f-location').focus();
    return;
  }

  // Create or update item object
  let item;
  if (isEdit) {
    item = inventory.find(i => i.id === isEdit);
    if (!item) {
      showToast('Item not found');
      return;
    }
    // Update existing item
    item.name = name;
    item.category = category;
    item.reorderPt = reorderPt;
    item.cost = cost;
    item.labor = labor;
    item.suggestedPrice = suggestedPrice;
    item.notes = notes || undefined;
  } else {
    // Create new item
    item = {
      id: uid(),
      name,
      category,
      reorderPt,
      cost,
      labor,
      suggestedPrice,
      notes: notes || undefined,
      unit: 'print', // Default unit
      sales: [],
      created: new Date().toISOString()
    };
    inventory.push(item);
  }

  // Handle warehouse transfer
  if (transferFromWarehouse && qty > 0) {
    try {
      await performWarehouseTransfer(item.id, location, qty);
      showToast(`✓ Transferred ${qty} units from warehouse to ${locations.find(l => l.id === location)?.name || location}`);

      // After successful transfer, reload item from server to get updated inventory
      try {
        const response = await fetch(`${API}/inventory`);
        const updatedInventory = await response.json();
        const updatedItem = Array.isArray(updatedInventory) ? updatedInventory.find(i => i.id === item.id) : null;
        if (updatedItem) {
          // Update local item with server state
          Object.assign(item, updatedItem);
          // Update in inventory array
          const idx = inventory.findIndex(i => i.id === item.id);
          if (idx > -1) inventory[idx] = item;
        }
      } catch (refreshError) {
        console.warn('Failed to refresh item after transfer:', refreshError);
      }
    } catch (transferError) {
      console.error('Warehouse transfer failed:', transferError);
      showToast('Failed to transfer from warehouse');
      return;
    }
  }

  // Save to server
  try {
    if (isEdit) {
      // For edits, use the updateItem action
      const patch = {
        name,
        category,
        reorderPt,
        cost,
        labor,
        suggestedPrice,
        notes: notes || undefined
      };

      const response = await fetch(`${API}/inventory?action=updateItem`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ itemId: isEdit, patch })
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }

      // Re-fetch inventory and re-render
      const updatedInventory = await fetch(`${API}/inventory`);
      inventory = await updatedInventory.json();
    } else {
      // For new items, still use PUT to save entire inventory
      const response = await fetch(`${API}/inventory`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(inventory)
      });

      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }
    }

    showToast(isEdit ? 'Item updated!' : 'Item added!');
    closeModal('modal-add');
    renderList();
  } catch (error) {
    console.error('Failed to save item:', error);
    showToast('Failed to save item');
  }
}

// ── Item Detail ────────────────────────────────────────────
function openDetail(id) { currentDetailId=id; renderDetail(); document.getElementById('modal-detail').classList.add('open'); }
function renderDetail() {
  const item=inventory.find(i=>i.id===currentDetailId); if(!item) return;
  const suggested=Number(item.suggestedPrice ?? item.salePrice ?? 0);

  // Calculate adjusted profit and margin after transaction fee
  const primaryLocationId = getItemPrimaryLocation(item);
  const location = locations.find(l => l.id === primaryLocationId);
  const transactionFeePercent = location?.transactionFeePercent || 0;
  const effectiveRevenue = suggested * (1 - transactionFeePercent / 100);
  const tc=Number(item.cost)+Number(item.labor);
  const adjustedProfit = effectiveRevenue - tc;
  const adjustedMargin = suggested > 0 ? (adjustedProfit / suggested * 100).toFixed(1) : 0;

  // Calculate total quantity across all locations
  const totalQty = item.totalQty || 0;

  document.getElementById('detail-name').textContent=item.name;
  document.getElementById('detail-cat').textContent=item.category;
  document.getElementById('detail-qty').textContent=totalQty;
  document.getElementById('detail-unit').textContent=item.unit||'units';
  document.getElementById('detail-profit').textContent=fmt(adjustedProfit);
  document.getElementById('detail-margin').textContent=adjustedMargin+'% margin (after '+transactionFeePercent+'% fee)';
  document.getElementById('dd-cost').textContent=fmt(item.cost);
  document.getElementById('dd-labor').textContent=fmt(item.labor);
  document.getElementById('dd-suggested-price').textContent=fmt(suggested);
  document.getElementById('dd-total-val').textContent=fmt(suggested*totalQty);

  // Handle image display
  const imageContainer = document.getElementById('detail-image-container');
  if (item.imageId) {
    const imageUrl = `/.netlify/functions/images?id=${item.imageId}`;
    imageContainer.innerHTML = `<div style="width:100%;height:200px;background:#f5f2ee;border-radius:12px;overflow:hidden;margin-bottom:16px;"><img src="${esc(imageUrl)}" alt="${esc(item.name)}" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display='none';this.parentElement.innerHTML='<div style=\\'width:100%;height:100%;background:#ede9e3;display:flex;align-items:center;justify-content:center;font-size:32px;color:#9a9080;\\'>📦</div>';"></div>`;
    imageContainer.style.display = 'block';
  } else {
    imageContainer.style.display = 'none';
  }

  const nw=document.getElementById('detail-notes-wrap');
  if(item.notes){nw.style.display='block';document.getElementById('detail-notes-edit').value=item.notes;}else nw.style.display='none';
  updateDetailNotesCounter();

  // Pre-fill sale section with suggested price
  document.getElementById('sale-qty').value='1';
  document.getElementById('sale-price-override').value=suggested > 0 ? suggested.toFixed(2) : '';
  document.getElementById('sale-date').value=new Date().toISOString().split('T')[0];

  // Populate location selector for multi-location items
  const locationGroup = document.getElementById('sale-location-group');
  const locationSelect = document.getElementById('sale-location');
  const recordSaleBtn = document.getElementById('record-sale-btn');

  // Check if item exists in multiple locations with stock
  const locationsWithStock = locations.filter(loc =>
    loc.active && item.inventory && item.inventory[loc.id] && Number(item.inventory[loc.id].qty) > 0
  );

  if (locationsWithStock.length > 1) {
    // Show location selector
    locationGroup.style.display = 'block';
    locationSelect.innerHTML = '<option value="">Select location...</option>';

    locationsWithStock.forEach(loc => {
      const qty = Number(item.inventory[loc.id].qty);
      const option = document.createElement('option');
      option.value = loc.id;
      option.textContent = `${loc.name} (${qty} ${item.unit || 'units'})`;
      locationSelect.appendChild(option);
    });

    // Clear any previous selection and disable button
    locationSelect.value = '';
    recordSaleBtn.disabled = true;
    recordSaleBtn.style.opacity = '0.5';
  } else {
    // Hide location selector for single location items
    locationGroup.style.display = 'none';
    locationSelect.value = '';
    recordSaleBtn.disabled = false;
    recordSaleBtn.style.opacity = '1';
  }

  // Add event listener to enable/disable button based on location selection
  locationSelect.onchange = function() {
    const isSelected = this.value !== '';
    recordSaleBtn.disabled = !isSelected;
    recordSaleBtn.style.opacity = isSelected ? '1' : '0.5';
  };

  // Sale history
  const sales=[...(item.sales||[])].sort((a,b)=>new Date(b.date)-new Date(a.date));
  const hw=document.getElementById('detail-sale-history-wrap');
  const hl=document.getElementById('detail-sale-history');
  if(sales.length){
    hw.style.display='block';
    hl.innerHTML=sales.map(s=>`<div class="pnl-row">
      <div>
        <div class="pnl-row-label">${s.qty} ${esc(item.unit||'units')} @ ${fmt(s.priceEach)}</div>
        <div style="font-size:11px;color:var(--text3);font-family:var(--font-mono)">${s.date?new Date(s.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}):'—'}</div>
      </div>
      <div style="display:flex;align-items:center;gap:10px;">
        <div>
          <div class="pnl-row-val pos" style="font-size:14px">${fmt(s.revenue)}</div>
          <div style="font-size:10px;color:var(--accent2);font-family:var(--font-mono);text-align:right">+${fmt(s.profit)} profit</div>
        </div>
        <button onclick="removeSale('${s.sid}')" style="background:none;border:none;color:var(--text3);font-size:18px;cursor:pointer;padding:2px 6px;min-width:32px;min-height:32px">×</button>
      </div>
    </div>`).join('');
  } else {
    hw.style.display='none';
  }
}

function recordSale() {
  const item=inventory.find(i=>i.id===currentDetailId); if(!item) return;
  const qty=parseInt(document.getElementById('sale-qty').value)||1;
  const suggested=Number(item.suggestedPrice ?? item.salePrice ?? 0);
  const priceEach=parseFloat(document.getElementById('sale-price-override').value)||suggested;
  const date=document.getElementById('sale-date').value;

  if(qty<=0){document.getElementById('sale-qty').focus();return;}

  // Initialize inventory object if it doesn't exist
  if (!item.inventory) item.inventory = {};

  // Determine the location where the sale occurred
  let saleLocation = null;
  let availableQty = 0;

  // Check if location selector is visible (multi-location item)
  const locationGroup = document.getElementById('sale-location-group');
  if (locationGroup.style.display !== 'none') {
    // Multi-location item - use selected location
    saleLocation = document.getElementById('sale-location').value;
    if (!saleLocation) {
      showToast('Please select a location for this sale');
      document.getElementById('sale-location').focus();
      return;
    }
    availableQty = Number(item.inventory[saleLocation]?.qty || 0);
  } else {
    // Single location item - use the first active location with available stock
    const activeLocations = locations.filter(loc => loc.active);
    for (const loc of activeLocations) {
      const locQty = Number(item.inventory[loc.id]?.qty || 0);
      if (locQty > 0) {
        saleLocation = loc.id;
        availableQty = locQty;
        break;
      }
    }
  }

   // Check if there's enough stock at the selected location
   if (!saleLocation || qty > availableQty) {
     const totalQty = Object.values(item.inventory).reduce((sum, loc) => sum + Number(loc.qty || 0), 0);
     showToast(`Only ${availableQty || totalQty} in stock at selected location`);
     return;
   }

  // Calculate transaction fee for this sale
  const location = locations.find(l => l.id === saleLocation);
  const transactionFeePercent = location?.transactionFeePercent || 0;

  fetch('/.netlify/functions/inventory?action=recordSale', {
    method: 'POST',
    headers: {'Content-Type':'application/json'},
    body: JSON.stringify({
      itemId: item.id,
      location: saleLocation,
      qtySold: qty,
      actualPrice: priceEach,
      date: date,
      feePercent: transactionFeePercent
    })
  }).then(response => {
    if (response.ok) {
      return fetch('/.netlify/functions/inventory');
    } else {
      throw new Error('Failed to record sale');
    }
  }).then(response => response.json()).then(updatedInventory => {
    inventory = updatedInventory;
    renderList();
    closeModal('modal-detail');
    showToast(`✓ Sold ${qty} ${item.unit||'unit'}${qty!==1?'s':''} for ${fmt(qty*priceEach)}${transactionFeePercent > 0 ? ` (${transactionFeePercent}% fee)` : ''}`);
  }).catch(error => {
    console.error(error);
    showToast('Failed to record sale');
  });
}

function removeSale(sid) {
  const item=inventory.find(i=>i.id===currentDetailId); if(!item) return;
  const sale=(item.sales||[]).find(s=>s.sid===sid); if(!sale) return;
  // Restore qty at the specific location where the sale occurred
  if (!item.inventory) item.inventory = {};
  if (!item.inventory[sale.location]) {
    item.inventory[sale.location] = { qty: 0, lastUpdated: new Date().toISOString() };
  }
  item.inventory[sale.location].qty = Number(item.inventory[sale.location].qty) + Number(sale.qty);
  item.inventory[sale.location].lastUpdated = new Date().toISOString();
  item.sales=item.sales.filter(s=>s.sid!==sid);
  saveInventory(); renderDetail(); renderList(); showToast('Sale removed');
}

function adjustQty(d) {
  const item=inventory.find(i=>i.id===currentDetailId); if(!item) return;
  if (!item.inventory) item.inventory = {};

  // For now, default to adjusting the first active location
  // In a future enhancement, we could add location selection in the detail view
  const activeLocations = locations.filter(loc => loc.active);
  const defaultLocation = activeLocations.length > 0 ? activeLocations[0].id : 'storage';

  const currentQty = Number(item.inventory[defaultLocation]?.qty || 0);
  const newQty = Math.max(0, currentQty + d);

  item.inventory[defaultLocation] = {
    qty: newQty,
    lastUpdated: new Date().toISOString()
  };

  saveInventory(); renderDetail(); renderList();
}
function removeImage() {
  const imageInput = document.getElementById('f-image');
  const imagePreview = document.getElementById('image-preview');
  const imageStatus = document.getElementById('image-status');

  // Clear the image URL
  delete imageInput.dataset.imageUrl;

  // Reset preview
  imagePreview.innerHTML = '📦';
  imagePreview.style.position = '';

  // Update status
  imageStatus.textContent = 'Image removed';
  imageStatus.style.color = 'var(--text3)';
}

// ── Image Modal Functions ───────────────────────────────────
let isDragging = false;
let startX, startY, initialX, initialY;
let currentScale = 1;
let currentRotation = 0;
let lastTouchDistance = 0;

function openImageModal(imageUrl, title) {
  const modal = document.getElementById('image-modal');
  const img = document.getElementById('image-modal-img');
  const caption = document.getElementById('image-modal-caption');

  // Reset transform state
  currentScale = 1;
  currentRotation = 0;
  img.style.transform = 'scale(1) rotate(0deg)';

  // Set the full-size image URL
  img.src = imageUrl;
  img.alt = title || 'Image';
  caption.textContent = title || '';

  // Store the URL for download
  img.dataset.downloadUrl = imageUrl;

  modal.classList.add('open');

  // Add event listeners for interaction
  setupImageModalEvents();
}

function closeImageModal() {
  const modal = document.getElementById('image-modal');
  modal.classList.remove('open');

  // Remove event listeners
  cleanupImageModalEvents();
}

function setupImageModalEvents() {
  const modal = document.getElementById('image-modal');
  const img = document.getElementById('image-modal-img');

  // Mouse events for desktop
  img.addEventListener('mousedown', startDrag);
  document.addEventListener('mousemove', drag);
  document.addEventListener('mouseup', endDrag);

  // Touch events for mobile
  img.addEventListener('touchstart', startDrag, { passive: false });
  document.addEventListener('touchmove', drag, { passive: false });
  document.addEventListener('touchend', endDrag);

  // Wheel for zoom
  img.addEventListener('wheel', handleWheel);

  // Double-click to reset
  img.addEventListener('dblclick', resetImageTransform);

  // Keyboard events
  document.addEventListener('keydown', handleKeyDown);

  // Click outside to close
  modal.addEventListener('click', handleModalClick);
}

function cleanupImageModalEvents() {
  const modal = document.getElementById('image-modal');
  const img = document.getElementById('image-modal-img');

  img.removeEventListener('mousedown', startDrag);
  document.removeEventListener('mousemove', drag);
  document.removeEventListener('mouseup', endDrag);

  img.removeEventListener('touchstart', startDrag);
  document.removeEventListener('touchmove', drag);
  document.removeEventListener('touchend', endDrag);

  img.removeEventListener('wheel', handleWheel);
  img.removeEventListener('dblclick', resetImageTransform);
  document.removeEventListener('keydown', handleKeyDown);
  modal.removeEventListener('click', handleModalClick);
}

function startDrag(e) {
  e.preventDefault();
  isDragging = true;

  if (e.type === 'touchstart') {
    const touch = e.touches[0];
    startX = touch.clientX;
    startY = touch.clientY;

    // Handle pinch-to-zoom
    if (e.touches.length === 2) {
      lastTouchDistance = getTouchDistance(e.touches[0], e.touches[1]);
    }
  } else {
    startX = e.clientX;
    startY = e.clientY;
  }

  const img = document.getElementById('image-modal-img');
  const transform = window.getComputedStyle(img).transform;
  if (transform !== 'none') {
    const matrix = new DOMMatrix(transform);
    initialX = matrix.m41;
    initialY = matrix.m42;
  } else {
    initialX = 0;
    initialY = 0;
  }
}

function drag(e) {
  if (!isDragging) return;
  e.preventDefault();

  let clientX, clientY;

  if (e.type === 'touchmove') {
    // Handle pinch-to-zoom
    if (e.touches.length === 2) {
      const distance = getTouchDistance(e.touches[0], e.touches[1]);
      const scaleChange = distance / lastTouchDistance;
      currentScale *= scaleChange;
      currentScale = Math.max(0.5, Math.min(3, currentScale));
      lastTouchDistance = distance;
      updateImageTransform();
      return;
    }

    const touch = e.touches[0];
    clientX = touch.clientX;
    clientY = touch.clientY;
  } else {
    clientX = e.clientX;
    clientY = e.clientY;
  }

  const deltaX = clientX - startX;
  const deltaY = clientY - startY;

  const img = document.getElementById('image-modal-img');
  img.style.transform = `scale(${currentScale}) rotate(${currentRotation}deg) translate(${initialX + deltaX}px, ${initialY + deltaY}px)`;
}

function endDrag(e) {
  if (!isDragging) return;
  isDragging = false;

  // Update initial position for next drag
  const img = document.getElementById('image-modal-img');
  const transform = window.getComputedStyle(img).transform;
  if (transform !== 'none') {
    const matrix = new DOMMatrix(transform);
    initialX = matrix.m41;
    initialY = matrix.m42;
  }
}

function handleWheel(e) {
  e.preventDefault();
  const delta = e.deltaY > 0 ? -0.1 : 0.1;
  currentScale += delta;
  currentScale = Math.max(0.5, Math.min(3, currentScale));
  updateImageTransform();
}

function handleKeyDown(e) {
  switch (e.key) {
    case 'Escape':
      closeImageModal();
      break;
    case 'r':
    case 'R':
      currentRotation += 90;
      updateImageTransform();
      break;
    case '+':
    case '=':
      currentScale = Math.min(3, currentScale + 0.1);
      updateImageTransform();
      break;
    case '-':
      currentScale = Math.max(0.5, currentScale - 0.1);
      updateImageTransform();
      break;
    case '0':
      resetImageTransform();
      break;
  }
}

function handleModalClick(e) {
  // Close if clicked outside the image
  if (e.target.id === 'image-modal') {
    closeImageModal();
  }
}

function resetImageTransform() {
  currentScale = 1;
  currentRotation = 0;
  initialX = 0;
  initialY = 0;
  updateImageTransform();
}

function updateImageTransform() {
  const img = document.getElementById('image-modal-img');
  img.style.transform = `scale(${currentScale}) rotate(${currentRotation}deg) translate(${initialX}px, ${initialY}px)`;
}

function getTouchDistance(touch1, touch2) {
  const dx = touch1.clientX - touch2.clientX;
  const dy = touch1.clientY - touch2.clientY;
  return Math.sqrt(dx * dx + dy * dy);
}

function downloadImage() {
  const img = document.getElementById('image-modal-img');
  const url = img.dataset.downloadUrl;
  if (url) {
    const a = document.createElement('a');
    a.href = url;
    a.download = 'image.jpg'; // Default filename
    a.click();
  }
}

function handleImageModalError() {
  const img = document.getElementById('image-modal-img');
  img.style.display = 'none';
  img.parentElement.innerHTML = '<div style="text-align:center;color:var(--text3);font-size:16px;">❌ Image failed to load</div>';
}

function editCurrentItem() { closeModal('modal-detail'); setTimeout(()=>openEditModal(currentDetailId),180); }

// ── Finance Period & Location State ───────────────────────────────────
let pnlPeriod = 'ytd';
let pnlLocationFilter = 'all';
let incomeStatementPeriod = 'ytd'; // Separate period for Income Statement
let incomeStatementLocationFilter = 'all'; // Separate location filter for Income Statement

function setPnLPeriod(p) {
  pnlPeriod = p;
  document.querySelectorAll('.pnl-period-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('pnl-period-'+p).classList.add('active');
  renderPnL();
}

function setPnLLocationFilter() {
  const select = document.getElementById('pnl-location-filter');
  pnlLocationFilter = select.value;
  renderPnL();
}

function setFinanceView() {
  const select = document.getElementById('finance-view-selector');
  const view = select.value;

  const financeViewControls = document.getElementById('finance-view-controls');
  const incomeStatementSection = document.getElementById('income-statement-section');
  const pnlSection = document.getElementById('pnl-section');
  const pnlControlsContainer = document.getElementById('pnl-controls-container');
  const inventorySummarySection = document.getElementById('inventory-summary-section');
  const inventorySummaryControls = document.getElementById('inventory-summary-controls');
  const individualSalesSection = document.getElementById('individual-sales-section');
  const individualSalesControls = document.getElementById('individual-sales-controls');

  // Always show view selector for navigation between finance views
  financeViewControls.style.display = 'block';

  // First, hide all sections and controls
  incomeStatementSection.style.display = 'none';
  pnlSection.style.display = 'none';
  pnlControlsContainer.style.display = 'none';
  inventorySummarySection.style.display = 'none';
  inventorySummaryControls.style.display = 'none';
  individualSalesSection.style.display = 'none';
  individualSalesControls.style.display = 'none';

  // Clear content from all sections to prevent content leakage
  document.getElementById('individual-sales-list').innerHTML = '';

  // Then show only the selected view
  if (view === 'income-statement') {
    incomeStatementSection.style.display = 'block';
    renderIncomeStatement();
  } else if (view === 'pnl') {
    pnlSection.style.display = 'block';
    pnlControlsContainer.style.display = 'block';
    populatePnLLocationFilter();
    renderPnL();
  } else if (view === 'inventory-summary') {
    inventorySummarySection.style.display = 'block';
    inventorySummaryControls.style.display = 'block';
    populateInventorySummaryLocationFilter();
    renderInventorySummary();
  } else if (view === 'individual-sales') {
    individualSalesSection.style.display = 'block';
    individualSalesControls.style.display = 'block';
    populateIndividualSalesLocationFilter();
    renderIndividualSales();
  }
}

function populatePnLLocationFilter() {
  const select = document.getElementById('pnl-location-filter');
  if (!select) return;

  // Clear existing options except "All Locations"
  select.innerHTML = '<option value="all">All Locations</option>';

  // Add active (non-archived) locations
  const activeLocations = locations.filter(loc => loc.active && !loc.archived);
  activeLocations.forEach(loc => {
    const option = document.createElement('option');
    option.value = loc.id;
    option.textContent = loc.name;
    select.appendChild(option);
  });

  // Set current selection - if current filter is archived, reset to "all"
  const currentLoc = locations.find(loc => loc.id === pnlLocationFilter);
  if (currentLoc && currentLoc.archived) {
    pnlLocationFilter = 'all';
  }
  select.value = pnlLocationFilter;
}

// ── Individual Sales ────────────────────────────────────────
let individualSalesPeriod = 'month'; // Default to "This Month"
let individualSalesLocationFilter = 'all'; // Default to "All Locations"

// Test function to verify location filtering works
function testIndividualSalesFiltering() {
  console.log('Testing Individual Sales filtering...');

  // Test 1: Check if location filter dropdown is populated
  populateIndividualSalesLocationFilter();
  const select = document.getElementById('individual-sales-location-filter');
  console.log(`Individual Sales location filter options: ${select ? select.options.length : 0}`);

  // Test 2: Test period bounds calculation
  const bounds = getIndividualSalesBounds();
  console.log(`Current period bounds: ${bounds.start.toISOString()} to ${bounds.end.toISOString()}`);

  // Test 3: Test sales data filtering
  const sales = getIndividualSalesData(bounds);
  console.log(`Filtered sales (${individualSalesLocationFilter}): ${sales.length}`);

  // Test 4: Test view switching
  setFinanceView();
  const viewSelect = document.getElementById('finance-view-selector');
  console.log(`Current view: ${viewSelect.value}`);

  console.log('Individual Sales filtering test complete');
}

function populateIndividualSalesLocationFilter() {
  const select = document.getElementById('individual-sales-location-filter');
  if (!select) return;

  // Clear existing options except "All Locations"
  select.innerHTML = '<option value="all">All Locations</option>';

  // Add active (non-archived) locations
  const activeLocations = locations.filter(loc => loc.active && !loc.archived);
  activeLocations.forEach(loc => {
    const option = document.createElement('option');
    option.value = loc.id;
    option.textContent = loc.name;
    select.appendChild(option);
  });

